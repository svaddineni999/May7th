<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>57.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>Assign EPE Id in message record</description>
        <name>Assign_EPE_Id_in_message_record</name>
        <label>Assign EPE Id in message record</label>
        <locationX>264</locationX>
        <locationY>815</locationY>
        <assignmentItems>
            <assignToReference>Message_Record.PC_SMSELetter__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Loop_On_EPE.Id</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Create_Message_Record_With_Status_Draft</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Adding Message Record Details</description>
        <name>Message_Record_Details</name>
        <label>Message Record Details</label>
        <locationX>264</locationX>
        <locationY>695</locationY>
        <assignmentItems>
            <assignToReference>Message_Record.Name</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Patient_Name</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Message_Record.PC_Type__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Outbound</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Message_Record.PC_Message_Status__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Draft</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Message_Record.PC_Message_Date__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Flow.CurrentDateTime</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Message_Record.PC_Case__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.PC_Program__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Message_Record.PC_ReceiverAccount__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.PC_Program__r.AccountId</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Message_Record.PC_SenderUser__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$User.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Message_Record.ACLS_SMS_Operation__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Send SMS</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Assign_EPE_Id_in_message_record</targetReference>
        </connector>
    </assignments>
    <constants>
        <name>two</name>
        <dataType>Number</dataType>
        <value>
            <numberValue>2.0</numberValue>
        </value>
    </constants>
    <decisions>
        <description>Check eLetter Type As SMS</description>
        <name>Check_eLetter_Type_As_SMS</name>
        <label>Check eLetter Type As SMS</label>
        <locationX>396</locationX>
        <locationY>575</locationY>
        <defaultConnector>
            <targetReference>Loop_On_EPE</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>if_SMS</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_On_EPE.PC_eLetter__r.PC_Category__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>SMS</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_On_EPE.PC_eLetter__r.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Missing_Information_Alert_Message</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Message_Record_Details</targetReference>
            </connector>
            <label>if = SMS</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>Patient_Name</name>
        <dataType>String</dataType>
        <expression>&apos;Message To -&apos;+{!$Record.PC_Program__r.Account.FirstName} + &apos; &apos;+{!$Record.PC_Program__r.Account.LastName}</expression>
    </formulas>
    <interviewLabel>Create Message Record On Task Creation {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Create Message Record On Task Creation</label>
    <loops>
        <description>Loop On Engagement Program eLetter</description>
        <name>Loop_On_EPE</name>
        <label>Loop On EPE</label>
        <locationX>176</locationX>
        <locationY>455</locationY>
        <collectionReference>Get_Engagement_Program_eLetter</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
