    <recordLookups>
        <name>PC_Get_PAP_Record_Type</name>
        <label>Get PAP Record Type</label>
        <locationX>513</locationX>
        <locationY>373</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>PC_Check_If_Case_Account_record</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>DeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>PC_PAP</stringValue>
            </value>
        </filters>
        <filters>
            <field>SobjectType</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Case</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>RecordType</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>PC_Get_Survey_Invitation_Related_Object_Records</name>
        <label>Get Survey Invitation Related Object Records</label>
        <locationX>433</locationX>
        <locationY>70</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>PC_CheckCategoryOfSubmittedSurvey</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>PC_SurveyInvitation__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <object>PC_SurveyInvitationRelatedObjects__c</object>
        <outputReference>PC_SurveyInvitationRelatedObjectRecord</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>PC_Account__c</queriedFields>
        <queriedFields>PC_Case__c</queriedFields>
        <queriedFields>PC_SurveyCategory__c</queriedFields>
        <queriedFields>PC_EngagementProgram__c</queriedFields>
        <queriedFields>PC_ResultingCase__c</queriedFields>
        <queriedFields>PC_SurveyInvitation__c</queriedFields>
    </recordLookups>
    <recordLookups>
        <name>PC_Get_Survey_Response</name>
        <label>Get Survey Response</label>
        <locationX>236</locationX>
        <locationY>417</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>PC_Get_Survey_Salary_Question</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>InvitationId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>SurveyResponse</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>PC_Get_Survey_Response_For_Salary_Question</name>
        <label>Get Survey Response For Salary Question</label>
        <locationX>49</locationX>
        <locationY>498</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>PC_Check_if_salary_is_less_than_20000</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>ResponseId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>PC_Get_Survey_Response.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>QuestionId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>PC_Survey_question_record_loop_element.Id</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>SurveyQuestionResponse</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>PC_Get_Survey_Salary_Question</name>
        <label>Get Survey Salary Question</label>
        <locationX>54</locationX>
        <locationY>368</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>PC_Survey_question_record_loop_element</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>SurveyVersionId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Survey.ActiveVersion.Id</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>SurveyQuestion</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>PC_update_Survey_Invitation_Related_Non_Program_records</name>
