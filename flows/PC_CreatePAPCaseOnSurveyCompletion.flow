<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>49.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>PC_Patient_is_eligible_for_PAP</name>
        <label>Patient is eligible for PAP</label>
        <locationX>410</locationX>
        <locationY>533</locationY>
        <assignmentItems>
            <assignToReference>PatientiseligibleforPAP</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>PC_lessThanOrEqualTo20000</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>PC_Get_PAP_Record_Type</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>PC_Patient_is_not_eligible_for_PAP</name>
        <label>Patient is not eligible for PAP</label>
        <locationX>413</locationX>
        <locationY>632</locationY>
        <assignmentItems>
            <assignToReference>PatientiseligibleforPAP</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>PC_Get_PAP_Record_Type</targetReference>
        </connector>
    </assignments>
    <decisions>
        <description>This decision will check if the referenced record is Case</description>
        <name>PC_Check_If_Case_Account_record</name>
        <label>Check If Case/Account record</label>
        <locationX>885</locationX>
        <locationY>65</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>PC_Is_Non_Program_case_record</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>PC_SurveyInvitationRelatedObjectRecord.PC_Case__r.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>PC_SurveyInvitationRelatedObjectRecord.PC_EngagementProgram__r.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>PC_SurveyInvitationRelatedObjectRecord.PC_Case__r.Type</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Program</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PC_Create_PAP_case_for_Non_Program_cases</targetReference>
            </connector>
            <label>Is Non-Program case record</label>
        </rules>
        <rules>
            <name>isAccountRecord</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>PC_SurveyInvitationRelatedObjectRecord.PC_Account__r.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>PC_SurveyInvitationRelatedObjectRecord.PC_EngagementProgram__r.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>PC_SurveyInvitationRelatedObjectRecord.PC_Case__r.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_PAP_case_for_Account</targetReference>
            </connector>
            <label>is Account Record</label>
        </rules>
        <rules>
            <name>PC_Is_Program_case_record</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>PC_SurveyInvitationRelatedObjectRecord.PC_Case__r.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>PC_SurveyInvitationRelatedObjectRecord.PC_EngagementProgram__r.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>PC_SurveyInvitationRelatedObjectRecord.PC_Case__r.Type</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Program</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PC_Create_PAP_Case_for_Program_Case</targetReference>
            </connector>
            <label>Is Program case record</label>
        </rules>
    </decisions>
    <decisions>
        <name>PC_Check_if_salary_is_less_than_20000</name>
        <label>Check if salary is less than 20000</label>
        <locationX>226</locationX>
        <locationY>541</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>PC_lessThanOrEqualTo20000</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>PC_Get_Survey_Response_For_Salary_Question.NumberValue</leftValueReference>
                <operator>WasSet</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>PC_Get_Survey_Response_For_Salary_Question.NumberValue</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>PC_Get_Survey_Response_For_Salary_Question.NumberValue</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>20000.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PC_Patient_is_eligible_for_PAP</targetReference>
            </connector>
            <label>lessThanOrEqualTo20000</label>
        </rules>
        <rules>
            <name>PC_greater_than_20000</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>PC_Get_Survey_Response_For_Salary_Question.NumberValue</leftValueReference>
                <operator>WasSet</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>PC_Get_Survey_Response_For_Salary_Question.NumberValue</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>PC_Get_Survey_Response_For_Salary_Question.NumberValue</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>20000.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PC_Patient_is_not_eligible_for_PAP</targetReference>
            </connector>
            <label>greater than 20000</label>
        </rules>
    </decisions>
    <decisions>
        <name>PC_CheckCategoryOfSubmittedSurvey</name>
        <label>Check category of submitted survey</label>
        <locationX>603</locationX>
        <locationY>180</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>PC_ChecIfItIsPAPSurvey</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>PC_SurveyInvitationRelatedObjectRecord</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>PC_SurveyInvitationRelatedObjectRecord.PC_SurveyCategory__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>PC_SurveyInvitationRelatedObjectRecord.PC_SurveyCategory__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>PC_PAP</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PC_Get_Survey_Response</targetReference>
            </connector>
            <label>Check if it is PAP survey</label>
        </rules>
    </decisions>
    <decisions>
        <name>PC_Verify_if_question_is_salary_question</name>
        <label>Verify if question is salary question</label>
        <locationX>98</locationX>
        <locationY>401</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>PC_Salary_question_exists</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>PC_Survey_question_record_loop_element.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Salary</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PC_Get_Survey_Response_For_Salary_Question</targetReference>
            </connector>
            <label>Salary question exists</label>
        </rules>
        <rules>
            <name>PC_Salary_question_does_not_exist</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>PC_Survey_question_record_loop_element.Name</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Salary</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PC_Survey_question_record_loop_element</targetReference>
            </connector>
            <label>Salary question does not exist</label>
        </rules>
    </decisions>
    <description>This flow would create a PAP case on survey completion when the required conditions are satisfied.</description>
    <interviewLabel>Create PAP Case On Survey Completion {!$Flow.CurrentDateTime}</interviewLabel>
    <isTemplate>true</isTemplate>
    <label>Create PAP Case On Survey Completion</label>
    <loops>
        <name>PC_Survey_question_record_loop_element</name>
        <label>Survey question record loop element</label>
        <locationX>411</locationX>
        <locationY>346</locationY>
        <collectionReference>PC_Get_Survey_Salary_Question</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>PC_Verify_if_question_is_salary_question</targetReference>
        </nextValueConnector>
    </loops>
