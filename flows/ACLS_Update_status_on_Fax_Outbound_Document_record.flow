    <recordLookups>
        <description>Get associated document record</description>
        <name>Get_associated_document_record</name>
        <label>Get associated document record</label>
        <locationX>842</locationX>
        <locationY>455</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
