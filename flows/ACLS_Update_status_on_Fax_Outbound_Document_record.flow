<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>57.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>Assign Value Of Document to Document Id</description>
        <name>Assign_Value_Of_Document_to_Document_Id</name>
        <label>Assign Value Of Document to Document Id</label>
        <locationX>842</locationX>
        <locationY>575</locationY>
        <assignmentItems>
            <assignToReference>DocumentId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Get_associated_document_record.Id</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Check_the_status_Of_Efaxs</targetReference>
        </connector>
    </assignments>
    <constants>
        <name>PC_Fax_Outbound</name>
        <dataType>String</dataType>
        <value>
            <stringValue>PC_Fax_Outbound</stringValue>
        </value>
    </constants>
    <constants>
        <name>Sent_Fax</name>
        <dataType>String</dataType>
        <value>
            <stringValue>Sent_Fax</stringValue>
        </value>
    </constants>
    <decisions>
        <description>Check RecordType of Fax</description>
        <name>Check_RecordType_of_Fax</name>
        <label>Check RecordType of Fax</label>
        <locationX>1370</locationX>
        <locationY>335</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Is_Record_Type_Sent_Fax</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Sent_Fax</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_associated_document_record</targetReference>
            </connector>
            <label>Is Record Type = Sent Fax</label>
        </rules>
    </decisions>
    <decisions>
        <description>Check the status Of Efax</description>
        <name>Check_the_status_Of_Efaxs</name>
        <label>Check the status Of Efax</label>
        <locationX>842</locationX>
        <locationY>695</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>if_status_NEW</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.EFX__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>NEW</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_document_status_to_New</targetReference>
            </connector>
            <label>if status = NEW</label>
        </rules>
        <rules>
            <name>if_status_ERROR</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.EFX__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ERROR</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_document_status_to_Failed</targetReference>
            </connector>
            <label>if status = ERROR</label>
        </rules>
        <rules>
            <name>if_Status_COMPLETE</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.EFX__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>COMPLETE</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_document_status_to_Sent</targetReference>
            </connector>
            <label>if Status = COMPLETE</label>
        </rules>
    </decisions>
    <description>Update status on Fax-Outbound Document record</description>
    <environments>Default</environments>
    <formulas>
        <name>ErrrorMessage</name>
        <dataType>String</dataType>
        <expression>{!Message} + {!DocumentId}</expression>
    </formulas>
    <interviewLabel>Update status on Fax-Outbound Document record {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Update status on Fax-Outbound Document record</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
