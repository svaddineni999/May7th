<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>57.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>Add Message Record Details</description>
        <name>Add_Message_Record_Details</name>
        <label>Add Message Record Details</label>
        <locationX>50</locationX>
        <locationY>539</locationY>
        <assignmentItems>
            <assignToReference>MessageRecord.PC_Type__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Outbound</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>MessageRecord.Name</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>PatientName</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>MessageRecord.PC_Message_Date__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Flow.CurrentDateTime</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>MessageRecord.PC_Message_Status__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Queued</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>MessageRecord.PC_ReceiverAccount__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>get_Existing_message_record.PC_Case__r.AccountId</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>MessageRecord.PC_SenderUser__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$User.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>MessageRecord.PC_Case__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>get_Existing_message_record.PC_Case__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>MessageRecord.ACLS_Program_Service_Permission__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>get_Existing_message_record.ACLS_Program_Service_Permission__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>MessageRecord.ACLS_SMS_Operation__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Send SMS</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>MessageRecord.ACLS_Interaction__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>get_Existing_message_record.ACLS_Interaction__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>MessageRecord.PC_Sender__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>get_Existing_message_record.PC_Sender__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>MessageRecord.PC_ExternalRecipientNumber__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>get_Existing_message_record.PC_ExternalRecipientNumber__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>MessageRecord.PC_Receiver__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>get_Existing_message_record.PC_Receiver__c</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>eLetters_from_Engagement_Program</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Assign EPE Id in message record</description>
        <name>Assign_EPE_Id_in_message_record</name>
        <label>Assign EPE Id in message record</label>
        <locationX>138</locationX>
        <locationY>971</locationY>
        <assignmentItems>
            <assignToReference>MessageRecord.PC_SMSELetter__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Loop_on_EPE.Id</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Pass_message_Data_to_Subflow</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Set Error message for exception</description>
        <name>Set_Error_message_for_exception</name>
        <label>Set Error message for exception</label>
        <locationX>1106</locationX>
        <locationY>647</locationY>
        <assignmentItems>
            <assignToReference>exceptionErrorMessage</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>ErrorMessage</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Get_PSP_record_Id</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Set Error message for exception</description>
        <name>SetErrormessageforexception</name>
        <label>Set Error message for exception</label>
        <locationX>1370</locationX>
        <locationY>539</locationY>
        <assignmentItems>
            <assignToReference>exceptionErrorMessage</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>ErrorMessage</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <isGoTo>true</isGoTo>
            <targetReference>Get_PSP_record_Id</targetReference>
        </connector>
    </assignments>
    <constants>
        <name>ACLS_Admin</name>
        <dataType>String</dataType>
        <value>
            <stringValue>ACLS_Admin</stringValue>
        </value>
    </constants>
    <constants>
        <name>PC_PSP_Task</name>
        <dataType>String</dataType>
        <value>
            <stringValue>PC_PSP_Task</stringValue>
        </value>
    </constants>
    <decisions>
        <description>Check eletter Type as SMS</description>
        <name>check_eletter_Type_as_SMS</name>
        <label>check eletter Type as SMS</label>
        <locationX>270</locationX>
        <locationY>863</locationY>
        <defaultConnector>
            <targetReference>Loop_on_EPE</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>if_SMS</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_on_EPE.PC_eLetter__r.PC_Category__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>SMS</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_on_EPE.PC_eLetter__r.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>SMSOutboundHelpSMS</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_EPE_Id_in_message_record</targetReference>
            </connector>
            <label>if SMS</label>
        </rules>
    </decisions>
    <decisions>
        <description>If Existing Message Record Available</description>
        <name>if_existing_message_record_available</name>
        <label>if existing message record available</label>
        <locationX>578</locationX>
        <locationY>431</locationY>
        <defaultConnector>
            <targetReference>Create_Error_Log_when_there_is_no_existing_Message_record</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>if_available</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>get_Existing_message_record</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.ACLS_SMS_Keyword__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>HELP</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Add_Message_Record_Details</targetReference>
            </connector>
            <label>if available</label>
        </rules>
        <rules>
            <name>ACLS_If_Keyword_is_Confirm</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>get_Existing_message_record</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.ACLS_SMS_Keyword__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>CONFIRM</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>ACLS_Update_Opt_In_Status_to_Opt_in_Confirmed</targetReference>
            </connector>
            <label>If Keyword is Confirm</label>
        </rules>
        <rules>
            <name>ACLS_If_Keyword_is_Stop</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>get_Existing_message_record</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.ACLS_SMS_Keyword__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>STOP</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>ACLS_Update_Opt_in_Status_to_Opt_out_Confirmed</targetReference>
            </connector>
            <label>If Keyword is Stop</label>
        </rules>
        <rules>
            <name>if_keyword_is_not_identified</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.ACLS_SMS_Keyword__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>CONFIRM</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.ACLS_SMS_Keyword__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>STOP</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.ACLS_SMS_Keyword__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>HELP</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Keyword_is_not_identified</targetReference>
            </connector>
            <label>if keyword is not identified</label>
        </rules>
    </decisions>
    <description>Inbound Message Record Actions</description>
    <environments>Default</environments>
    <formulas>
        <name>PatientName</name>
        <dataType>String</dataType>
        <expression>&quot;Message To - &quot; + {!get_Existing_message_record.PC_Case__r.Account.FirstName} +&quot; &quot; + {!get_Existing_message_record.PC_Case__r.Account.LastName}</expression>
    </formulas>
    <interviewLabel>Inbound Message Record Actions {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Inbound Message Record Actions</label>
    <loops>
