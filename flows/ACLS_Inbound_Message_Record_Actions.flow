    <recordUpdates>
        <description>Update Opt In Status to Opt in Confirmed</description>
        <name>ACLS_Update_Opt_In_Status_to_Opt_in_Confirmed</name>
        <label>Update Opt In Status to Opt in Confirmed</label>
        <locationX>314</locationX>
        <locationY>539</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>get_Existing_message_record.ACLS_Program_Service_Permission__r.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>ACLS_Opt_In_Status__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <inputAssignments>
            <field>ACLS_Opt_In_Status__c</field>
            <value>
                <stringValue>Opt In Confirmed</stringValue>
            </value>
        </inputAssignments>
        <object>PC_Program_Service_Permission__c</object>
    </recordUpdates>
    <recordUpdates>
        <description>Update Opt in Status to Opt out Confirmed</description>
        <name>ACLS_Update_Opt_in_Status_to_Opt_out_Confirmed</name>
        <label>Update Opt in Status to Opt out Confirmed</label>
        <locationX>578</locationX>
        <locationY>539</locationY>
        <filterLogic>1 AND (2 OR 3)</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>get_Existing_message_record.ACLS_Program_Service_Permission__r.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>ACLS_Opt_In_Status__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>ACLS_Opt_In_Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Opt In Confirmed</stringValue>
            </value>
