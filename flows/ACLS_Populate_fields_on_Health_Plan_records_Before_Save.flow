<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>57.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>This flow will be used to populate fields on the health plan record, before it is saved in salesforce</description>
    <environments>Default</environments>
    <interviewLabel>Populate fields on Health Plan records - Before Save {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Populate fields on Health Plan records - Before Save</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>Update &apos;Checked by Lookup service&apos; as true</description>
        <name>Update_Health_Plan_record</name>
        <label>Update Health Plan record</label>
        <locationX>176</locationX>
        <locationY>311</locationY>
        <inputAssignments>
            <field>PC_Created_By_Lookup_Service__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Health_Plan_record</targetReference>
        </connector>
        <object>PC_Health_Plan__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
