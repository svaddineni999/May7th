    <validationRules>
        <fullName>PC_HealthPlanSelectionValidation</fullName>
        <active>true</active>
        <errorConditionFormula>NOT(ISBLANK(PC_Health_Plan__c )) &amp;&amp; (PC_Health_Plan__r.Patient__r.Id  &lt;&gt;   PC_Program__r.Account.Id)</errorConditionFormula>
        <errorDisplayField>PC_Health_Plan__c</errorDisplayField>
        <errorMessage>Health plans related to the patient can only be selected.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>PC_ProgramType_Validation</fullName>
        <active>true</active>
        <description>This validation rule checks for the case type &quot;Program&quot; on field &quot;PC_Program__c&quot;</description>
        <errorConditionFormula>IF(OR(ISBLANK( PC_Program__c), ISNULL(PC_Program__c)), FALSE, NOT(ISPICKVAL(PC_Program__r.Type, &quot;Program&quot;)))</errorConditionFormula>
        <errorDisplayField>PC_Program__c</errorDisplayField>
        <errorMessage>Case selected must be of the type Program</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
