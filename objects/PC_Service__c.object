        <fullName>Positive_Expiration_Days</fullName>
        <active>true</active>
        <description>Does not allow users to enter negative value</description>
        <errorConditionFormula>IF( PC_Default_Expiration_Days__c &lt; 0 , true, false)</errorConditionFormula>
        <errorDisplayField>PC_Default_Expiration_Days__c</errorDisplayField>
        <errorMessage>Default Expiration Days can not be negative</errorMessage>
    </validationRules>
