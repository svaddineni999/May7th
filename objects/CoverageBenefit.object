                    <label>Secondary</label>
                </value>
                <value>
                    <fullName>Tertiary</fullName>
                    <default>false</default>
                    <label>Tertiary</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>PC_CoverageStatus__c</fullName>
        <deprecated>false</deprecated>
        <description>Indicates the patient&apos;s insurance policy status. The status types are:
• Active: If the patient&apos;s insurance policy status is active.
• Inactive: If the patient&apos;s insurance policy status is inactive.
• Incomplete: If the patient&apos;s insurance policy status is incomplete.
• Ineligible: If the patient&apos;s insurance policy status is not eligible.
• Undetermined: If the patient&apos;s insurance policy status cannot be determined.</description>
        <label>Coverage Status</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Active</fullName>
                    <default>false</default>
                    <label>Active</label>
                </value>
                <value>
                    <fullName>Inactive</fullName>
                    <default>false</default>
                    <label>Inactive</label>
                </value>
                <value>
                    <fullName>Incomplete</fullName>
                    <default>false</default>
                    <label>Incomplete</label>
                </value>
                <value>
                    <fullName>Ineligible</fullName>
                    <default>false</default>
                    <label>Ineligible</label>
                </value>
                <value>
                    <fullName>Undetermined</fullName>
                    <default>false</default>
                    <label>Undetermined</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
