    <fields>
        <fullName>PC_BillingMessage__c</fullName>
        <deprecated>false</deprecated>
        <description>Message received after the billing process is completely executed.</description>
        <externalId>false</externalId>
        <label>Billing Message</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
