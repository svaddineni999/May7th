        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_BuyAndBill__c</fullName>
        <deprecated>false</deprecated>
        <description>Indicates if buying and billing is permitted or not.  The status types are:
• Yes: If buying and billing is permitted.
•  No: If buying and billing is not permitted.
•  Undetermined: If you cannot determine whether buying and billing is permitted or not.
•  N/A: If buying and billing is not applicable.</description>
        <label>Buy And Bill</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Yes</fullName>
                    <default>false</default>
                    <label>Yes</label>
                </value>
                <value>
                    <fullName>No</fullName>
                    <default>false</default>
                    <label>No</label>
                </value>
                <value>
                    <fullName>Undetermined</fullName>
                    <default>false</default>
                    <label>Undetermined</label>
                </value>
                <value>
                    <fullName>N/A</fullName>
                    <default>false</default>
                    <label>N/A</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>PC_CoverageLevel__c</fullName>
        <deprecated>false</deprecated>
        <description>Indicates the type of the health plan associated with the patient. The types of health plan are:
        • Primary: If it is a primary health plan.
            • Secondary: If it is a secondary health plan.</description>
        <label>Coverage Level</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
