    <validationRules>
        <fullName>PC_Validate_Cardholder_Date_of_Birth</fullName>
        <active>true</active>
        <errorConditionFormula>PC_Cardholder_s_Date_of_Birth__c   &gt;   TODAY()</errorConditionFormula>
        <errorDisplayField>PC_Cardholder_s_Date_of_Birth__c</errorDisplayField>
        <errorMessage>Cardholder&apos;s Date of Birth cannot be in future.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>PC_Validate_Effective_Date</fullName>
        <active>true</active>
        <errorConditionFormula>PC_Effective_Date__c  &gt;  PC_Expiration_Date__c  || PC_Effective_Date__c &gt; PC_Renewal_Date__c</errorConditionFormula>
        <errorDisplayField>PC_Effective_Date__c</errorDisplayField>
        <errorMessage>Effective Date must be same or older than Expiration Date and Renewal Date.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>PC_Validate_Payer</fullName>
        <active>true</active>
        <description>Select Account of record type Payer</description>
        <errorConditionFormula>AND(PC_Payer__r.RecordType.Name != &apos;Payer&apos;,  NOT( ISBLANK(PC_Payer__c )))</errorConditionFormula>
        <errorDisplayField>PC_Payer__c</errorDisplayField>
        <errorMessage>Please select Account of record type Payer</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
