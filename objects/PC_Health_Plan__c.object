        <fullName>PC_PBM_Name__c</fullName>
        <deprecated>false</deprecated>
        <description>PBM name as returned by Pharmacy Card Lookup service or Payer name if no PBM name returned</description>
        <externalId>false</externalId>
        <formula>IF(
ISBLANK(PC_Payer__c)== true,
            PC_PBM_Name_as_per_Card_Lookup_Service__c ,
PC_Payer__r.Name
)</formula>
        <label>PBM Name</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
