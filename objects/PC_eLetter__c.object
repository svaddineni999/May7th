    <fields>
        <fullName>PC_AllowExternalRecipients__c</fullName>
        <defaultValue>false</defaultValue>
        <deprecated>false</deprecated>
        <description>Allow sending of email to any recipient irrespective of whether they are configured in Target Recipients or Pre-Configured Recipients(in the related Engagement Program Eletter record).</description>
        <inlineHelpText>Allow sending of email to any recipient irrespective of whether they are configured in Target Recipients or Pre-Configured Recipients(in the related Engagement Program Eletter record).</inlineHelpText>
        <label>Allow Additional Recipients</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>PC_Allow_Send_to_Patient__c</fullName>
        <defaultValue>false</defaultValue>
        <deprecated>false</deprecated>
        <description>Selecting this field allows the eLetter to be sent to the patients.</description>
        <label>Allow Send to Patient</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>PC_Category__c</fullName>
        <deprecated>false</deprecated>
        <description>Defines the category of the eLetter. i.e whether the eLetter is used for Email, Fax or Automated Email.</description>
        <label>Category</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>MultiselectPicklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Email</fullName>
                    <default>false</default>
                    <label>Email</label>
                </value>
                <value>
                    <fullName>Fax</fullName>
                    <default>false</default>
                    <label>Fax</label>
                </value>
                <value>
                    <fullName>SMS</fullName>
                    <default>false</default>
                    <label>SMS</label>
                </value>
                <value>
                    <fullName>Automated Email</fullName>
                    <default>false</default>
                    <label>Automated Email</label>
                </value>
                <value>
                    <fullName>Automated Fax</fullName>
                    <default>false</default>
                    <label>Automated Fax</label>
                </value>
                <value>
                    <fullName>Automated SMS</fullName>
                    <default>false</default>
                    <label>Automated SMS</label>
                </value>
            </valueSetDefinition>
        </valueSet>
        <visibleLines>4</visibleLines>
    </fields>
