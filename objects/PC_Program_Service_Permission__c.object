    <allowInChatterGroups>false</allowInChatterGroups>
    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <deploymentStatus>Deployed</deploymentStatus>
    <deprecated>false</deprecated>
    <description>Holds patient&apos;s (program&apos;s) consent for a Service.</description>
    <enableActivities>true</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>false</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>Private</externalSharingModel>
    <fields>
        <fullName>ACLS_Engagement_Program_Code__c</fullName>
        <externalId>false</externalId>
        <label>Engagement Program Code</label>
        <length>100</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>ACLS_HCP_Expiration_Date__c</fullName>
        <description>HCP Expiration Date</description>
        <label>HCP Expiration Date</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>ACLS_HCP_Permission_Required__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Checkbox to check if HCP permission is required</description>
        <label>HCP Permission Required</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>ACLS_HCP_Signed_Date__c</fullName>
        <label>HCP Signed Date</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>ACLS_Opt_In_Status__c</fullName>
        <label>Opt In Status</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Opt In Confirmed</fullName>
                    <default>false</default>
                    <label>Opt In Confirmed</label>
                </value>
                <value>
                    <fullName>Opt Out Confirmed</fullName>
                    <default>false</default>
                    <label>Opt Out Confirmed</label>
                </value>
                <value>
                    <fullName>Opt In Unconfirmed</fullName>
                    <default>false</default>
                    <label>Opt In Unconfirmed</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>ACLS_PT_Legal_GUA_Permission_Required__c</fullName>
        <defaultValue>false</defaultValue>
        <description>checkbox to check Patient / Legal Guardian Permission is Required</description>
        <label>PT/ Legal GUA Permission Required</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>ACLS_Patient_Expiration_Date__c</fullName>
        <description>Patient Expiration Date</description>
        <label>Patient Expiration Date</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>ACLS_Patient_Signed_Date__c</fullName>
        <label>Patient Signed Date</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
