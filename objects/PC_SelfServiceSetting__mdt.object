<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Settings to configure self services provided per engagement program</description>
    <fields>
        <fullName>PC_Active__c</fullName>
        <defaultValue>false</defaultValue>
        <deprecated>false</deprecated>
        <description>Should be checked if the service configured needs to be listed to caller</description>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Active</label>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>PC_Channel__c</fullName>
        <deprecated>false</deprecated>
        <description>self service channel</description>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Channel</label>
        <required>false</required>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>CTI</fullName>
                    <default>true</default>
                    <label>CTI</label>
                </value>
                <value>
                    <fullName>Other</fullName>
                    <default>false</default>
                    <label>Other</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>PC_DownstreamFlowIdentifier__c</fullName>
        <deprecated>false</deprecated>
        <description>Unique identifier for the flow that need to be executed after Service flow is run</description>
        <externalId>false</externalId>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Downstream Flow Identifier</label>
        <length>255</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_EngagementProgram__c</fullName>
        <deprecated>false</deprecated>
        <description>The Engagement program to which the Service is associated to</description>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Engagement Program</label>
        <referenceTo>PC_EngagementProgram__mdt</referenceTo>
        <relationshipName>PC_SelfServiceSettings_EngagementProgram</relationshipName>
        <required>false</required>
        <type>MetadataRelationship</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_Order__c</fullName>
        <deprecated>false</deprecated>
        <description>Order in which services need to be read out to caller</description>
        <externalId>false</externalId>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Order</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_OtherChannel__c</fullName>
        <deprecated>false</deprecated>
        <description>Specify Other channel name if &quot;Other&quot; is selected in Channel</description>
        <externalId>false</externalId>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Other Channel</label>
        <length>255</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_ServiceFlowIdentifier__c</fullName>
        <deprecated>false</deprecated>
        <description>Unique identifier for the service flow</description>
        <externalId>false</externalId>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Service Flow Identifier</label>
        <length>255</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_ServiceName__c</fullName>
        <deprecated>false</deprecated>
        <description>Name of the service that is offered
Ex: Cancel Appointment</description>
        <externalId>false</externalId>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Service Name</label>
        <length>255</length>
        <required>true</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_VendorName__c</fullName>
        <deprecated>false</deprecated>
        <description>Name of the vendor for which services configuration is done.
Ex: Amazon Connect</description>
        <externalId>false</externalId>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Vendor Name</label>
        <length>255</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>Self Service Setting</label>
    <pluralLabel>Self Service Settings</pluralLabel>
    <visibility>Public</visibility>
</CustomObject>
