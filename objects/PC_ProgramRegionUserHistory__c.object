    <fields>
        <fullName>PC_CareTeamAccount__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <deprecated>false</deprecated>
        <description>This field is used to store the name of the Care Team Account of the Program Region User Mapping record for which Associate record is created.</description>
        <label>Care Team Account</label>
        <referenceTo>Account</referenceTo>
        <relationshipLabel>Program Region User Histories</relationshipLabel>
        <relationshipName>PC_ProgramRegionUserHistories</relationshipName>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>PC_CareTeamRole__c</fullName>
        <deprecated>false</deprecated>
        <description>This field is used to store the Care Team Role of the Program Region User Mapping record for which Associate record is created.</description>
        <label>Care Team Role</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>HCO</fullName>
                    <default>false</default>
                    <label>HCO</label>
                </value>
                <value>
                    <fullName>Treating Physician</fullName>
                    <default>false</default>
                    <label>Treating Physician</label>
                </value>
                <value>
                    <fullName>Care Coordinator</fullName>
                    <default>false</default>
                    <label>Care Coordinator</label>
                </value>
                <value>
                    <fullName>Reimbursement Specialist</fullName>
                    <default>false</default>
                    <label>Reimbursement Specialist</label>
                </value>
                <value>
                    <fullName>Field Reimbursement Manager</fullName>
                    <default>false</default>
                    <label>Field Reimbursement Manager</label>
                </value>
                <value>
                    <fullName>Case Manager</fullName>
                    <default>false</default>
                    <label>Case Manager</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
