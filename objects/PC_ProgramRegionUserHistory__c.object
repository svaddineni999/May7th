    <fields>
        <fullName>PC_QueueOrGroupName__c</fullName>
        <deprecated>false</deprecated>
        <description>Contains the Name of the User Queue or Group of the Association. Leave it blank, if the PC_RoleType is blank.</description>
        <externalId>false</externalId>
        <inlineHelpText>Contains the Name of the User Queue or Group of the Association. Leave it blank, if the PC_RoleType is blank.</inlineHelpText>
        <label>User Queue/Group Name</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_Region__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <deprecated>false</deprecated>
        <description>This field is used to store the Region of the Program Region User Mapping record for which Associate record is created.</description>
        <label>Region</label>
        <referenceTo>PC_Region__c</referenceTo>
        <relationshipLabel>Program Region User Histories</relationshipLabel>
        <relationshipName>PC_ProgramRegionUserHistories</relationshipName>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>PC_RoleType__c</fullName>
        <deprecated>false</deprecated>
        <description>Indicates if the role type is User Queue or Group.
Blank value signifies anything other than Queue or Group.</description>
        <inlineHelpText>Indicates if the role type is User Queue or Group.
Blank value signifies anything other than Queue or Group.</inlineHelpText>
        <label>Role Type</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Queue</fullName>
                    <default>false</default>
                    <label>Queue</label>
                </value>
                <value>
                    <fullName>Group</fullName>
                    <default>false</default>
                    <label>Group</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <label>Program Region User History</label>
    <listViews>
        <fullName>All</fullName>
        <filterScope>Everything</filterScope>
        <label>All</label>
    </listViews>
    <nameField>
        <displayFormat>PRUH{0}</displayFormat>
        <label>Program Region User History Name</label>
        <trackHistory>false</trackHistory>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Program Region User History</pluralLabel>
    <searchLayouts/>
    <sharingModel>Read</sharingModel>
    <validationRules>
        <fullName>PC_User_and_Account_values_check</fullName>
        <active>true</active>
        <description>This rule will ensure to have value in only one of &apos;Care Team Account&apos; and &apos;Care Team User&apos;.</description>
        <errorConditionFormula>OR(AND(ISBLANK( PC_CareTeamAccount__c ), ISBLANK( PC_CareTeamUser__c ) ),
AND( NOT(ISBLANK( PC_CareTeamAccount__c )), NOT(ISBLANK( PC_CareTeamUser__c ) ) ))</errorConditionFormula>
        <errorMessage>Please enter only one of &apos;Care Team Account&apos; and &apos;Care Team User&apos;.</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
