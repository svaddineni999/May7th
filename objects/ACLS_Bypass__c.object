<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <customSettingsType>Hierarchy</customSettingsType>
    <description>This custom setting is used to skip validations and triggers. Per user setting.</description>
    <enableFeeds>false</enableFeeds>
    <fields>
        <fullName>ACLS_Skip_Validations__c</fullName>
        <defaultValue>false</defaultValue>
        <label>Skip Validations</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <label>Bypass Custom Validations</label>
    <visibility>Public</visibility>
</CustomObject>
