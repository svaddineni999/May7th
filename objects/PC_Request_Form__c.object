    <allowInChatterGroups>false</allowInChatterGroups>
    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <deploymentStatus>Deployed</deploymentStatus>
    <deprecated>false</deprecated>
    <description>To track the consent templates that exist for different programs, their versions, and so on.</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>false</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>Private</externalSharingModel>
    <fields>
        <fullName>PC_Active__c</fullName>
        <deprecated>false</deprecated>
        <description>Indicates if the request/consent form is active and can be used.</description>
        <formula>IF( (ISBLANK( PC_Retirement_Date__c ) ||  ISNULL(PC_Retirement_Date__c ) || 
     PC_Retirement_Date__c &gt;= TODAY()) &amp;&amp;  NOT(ISBLANK(PC_Release_Date__c)) , true, false)</formula>
        <label>Active</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>PC_Engagement_Program__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <deprecated>false</deprecated>
        <description>Contains the engagement program detail.</description>
        <label>Engagement Program</label>
        <referenceTo>PC_Engagement_Program__c</referenceTo>
        <relationshipLabel>Request Forms</relationshipLabel>
        <relationshipName>PC_Request_Forms</relationshipName>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>PC_External_Id__c</fullName>
        <caseSensitive>false</caseSensitive>
        <deprecated>false</deprecated>
        <description>The user-entered unique form name or code.</description>
        <externalId>true</externalId>
        <label>External Id</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>true</unique>
    </fields>
    <fields>
        <fullName>PC_Release_Date__c</fullName>
        <deprecated>false</deprecated>
        <description>The date on which the current version of request form/consent form was released.</description>
        <label>Release Date</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>PC_Retirement_Date__c</fullName>
        <deprecated>false</deprecated>
        <description>The date on which the current version of request form/consent form was retired.</description>
        <label>Retirement Date</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>PC_Script__c</fullName>
        <deprecated>false</deprecated>
        <description>The content in the request/consent form.</description>
        <label>Script</label>
        <length>32768</length>
        <trackTrending>false</trackTrending>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
    <fields>
        <fullName>PC_Version__c</fullName>
        <deprecated>false</deprecated>
        <description>The version name of the request form.</description>
        <externalId>false</externalId>
        <label>Version</label>
        <length>10</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>Request Form</label>
    <listViews>
        <fullName>All</fullName>
        <filterScope>Everything</filterScope>
        <label>All</label>
    </listViews>
    <nameField>
        <label>Request Form Name</label>
        <type>Text</type>
    </nameField>
    <pluralLabel>Request Forms</pluralLabel>
    <searchLayouts/>
    <sharingModel>ReadWrite</sharingModel>
    <visibility>Public</visibility>
</CustomObject>
