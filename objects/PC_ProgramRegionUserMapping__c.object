    <searchLayouts/>
    <sharingModel>Read</sharingModel>
    <validationRules>
        <fullName>PC_Care_Team_Account_Check</fullName>
        <active>true</active>
        <description>This rule is to make sure that &apos;Care Team Member&apos; is selected for roles &apos;Care Coordinator&apos; and &apos;Reimbursement Specialist&apos;</description>
        <errorConditionFormula>AND((ISPICKVAL(PC_CareTeamRole__c, &apos;HCO&apos; ) || ISPICKVAL(PC_CareTeamRole__c, &apos;Treating Physician&apos;) ),( ISBLANK( PC_CareTeamAccount__c ) &amp;&amp; NOT(ISBLANK( PC_CareTeamMember__c ))))</errorConditionFormula>
        <errorMessage>Please add value in &apos;Care Team Account&apos; if &apos;Care Team Role&apos; is selected as &apos;Treating Physician&apos; or &apos;HCO&apos;.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>PC_Care_Team_Role_Check</fullName>
        <active>true</active>
        <description>This rule is to make sure that &apos;Care Team Account&apos; is selected for roles &apos;HCO&apos; and &apos;Treating Physician&apos;</description>
        <errorConditionFormula>AND((ISPICKVAL(PC_CareTeamRole__c, &apos;Care Coordinator&apos; ) || ISPICKVAL(PC_CareTeamRole__c, &apos;Reimbursement Specialist&apos;) ),( ISBLANK( PC_CareTeamMember__c ) &amp;&amp; NOT(ISBLANK( PC_CareTeamAccount__c ))))</errorConditionFormula>
        <errorMessage>Please add value in &apos;Care Team Member&apos; if &apos;Care Team Role&apos; is selected as &apos;Care Coordinator&apos; or &apos;Reimbursement Specialist&apos;.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>PC_HCO_RoleAndAccount_Combination</fullName>
        <active>true</active>
        <description>This rule will make sure that &apos;Care Team Account&apos; of type &apos;HCO&apos; is selected for &apos;Care Team Role&apos; of value &apos;HCO&apos;</description>
        <errorConditionFormula>(PC_CareTeamAccount__r.RecordType.DeveloperName != &apos;HCO&apos; &amp;&amp; PC_CareTeamAccount__c!= null &amp;&amp; Text(PC_CareTeamRole__c) == &apos;HCO&apos;)</errorConditionFormula>
        <errorMessage>Please select &apos;Care Team Account&apos; of type &apos;HCO&apos; for the selected &apos;Care Team Role&apos; HCO</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>PC_Physician_RoleAndAccount_Combination</fullName>
        <active>true</active>
        <description>This rule will make sure that &apos;Care Team Account&apos; of type &apos;Physician&apos; is selected for &apos;Care Team Role&apos; of value &apos;Treating Physician&apos;</description>
        <errorConditionFormula>( PC_CareTeamAccount__r.RecordType.DeveloperName != &apos;PC_Physician&apos; &amp;&amp; PC_CareTeamAccount__c!= null &amp;&amp; Text(PC_CareTeamRole__c) == &apos;Treating Physician&apos;)</errorConditionFormula>
        <errorMessage>Please select &apos;Care Team Account&apos; of type &apos;Physician&apos; for the selected &apos;Care Team Role&apos; Treating Physician</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>User_and_Account_values_check</fullName>
        <active>true</active>
        <description>This rule will ensure to have value only in one of &apos;Care Team Account&apos; and &apos;Care Team User&apos;.</description>
        <errorConditionFormula>OR(AND(ISBLANK( PC_CareTeamAccount__c ), ISBLANK(  PC_CareTeamMember__c ) ),
AND( NOT(ISBLANK( PC_CareTeamAccount__c )), NOT(ISBLANK( PC_CareTeamMember__c ) ) ))</errorConditionFormula>
        <errorMessage>Please enter only one of &apos;Care Team Account&apos; and &apos;Care Team User&apos;.</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
