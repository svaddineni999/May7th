        <fullName>PC_Ordinal__c</fullName>
        <deprecated>false</deprecated>
        <description>This fields holds the sequential order of Program Region User Mapping records for unique Region, Role and Engagement Program records</description>
        <externalId>false</externalId>
        <label>Ordinal</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
