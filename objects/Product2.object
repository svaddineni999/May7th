    <fields>
        <fullName>PC_Brand_Name__c</fullName>
        <deprecated>false</deprecated>
        <description>Manufacture Brand that the product is associated with.</description>
        <externalId>false</externalId>
        <label>Brand Name</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_CPT_Codes__c</fullName>
        <deprecated>false</deprecated>
        <label>CPT Codes</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>MultiselectPicklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>96372</fullName>
                    <default>false</default>
                    <label>96372: therapeutic, prophylactic, or diagnostic injection</label>
                </value>
                <value>
                    <fullName>J3490</fullName>
                    <default>false</default>
                    <label>J3490</label>
                </value>
            </valueSetDefinition>
        </valueSet>
        <visibleLines>4</visibleLines>
    </fields>
    <fields>
        <fullName>PC_Form__c</fullName>
        <deprecated>false</deprecated>
        <description>Form of the drug. Injection, Solution, Pill.</description>
        <externalId>false</externalId>
        <label>Form</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_Manufacturer__c</fullName>
        <deleteConstraint>Restrict</deleteConstraint>
        <deprecated>false</deprecated>
        <description>lookup to the manufacturer account the product is associated to</description>
        <label>Manufacturer</label>
        <lookupFilter>
            <active>true</active>
            <booleanFilter>1 OR 2</booleanFilter>
            <errorMessage>Manufacturer does not exist. Please select a valid Manufacturer account.</errorMessage>
            <filterItems>
                <field>Account.RecordType.DeveloperName</field>
                <operation>equals</operation>
                <value>Manufacturer</value>
            </filterItems>
            <filterItems>
                <field>Account.RecordType.DeveloperName</field>
                <operation>equals</operation>
                <value>Franchise</value>
            </filterItems>
            <isOptional>false</isOptional>
        </lookupFilter>
        <referenceTo>Account</referenceTo>
        <relationshipLabel>Products</relationshipLabel>
        <relationshipName>Products</relationshipName>
        <required>true</required>
        <trackHistory>false</trackHistory>
        <type>Lookup</type>
    </fields>
    <fields>
