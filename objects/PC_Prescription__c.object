    <allowInChatterGroups>false</allowInChatterGroups>
    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <deploymentStatus>Deployed</deploymentStatus>
    <deprecated>false</deprecated>
    <description>This Object captures prescription information for the prescribed drug for a patient when enrolled in an engagement program.</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>false</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>Private</externalSharingModel>
    <fieldSets>
        <fullName>ACLS_Doc_Link_Prescription</fullName>
        <description>Field set used to display out-of-the-box Prescription fields on Document Link screen.</description>
        <displayedFields>
            <field>Name</field>
            <isFieldManaged>false</isFieldManaged>
            <isRequired>false</isRequired>
        </displayedFields>
        <displayedFields>
            <field>PC_Product__c</field>
            <isFieldManaged>false</isFieldManaged>
            <isRequired>false</isRequired>
        </displayedFields>
        <displayedFields>
            <field>PC_Program_Case__c</field>
            <isFieldManaged>false</isFieldManaged>
            <isRequired>false</isRequired>
        </displayedFields>
        <displayedFields>
            <field>PC_Patient_Account__c</field>
            <isFieldManaged>false</isFieldManaged>
            <isRequired>false</isRequired>
        </displayedFields>
        <displayedFields>
            <field>PC_Rx_Status__c</field>
            <isFieldManaged>false</isFieldManaged>
            <isRequired>false</isRequired>
        </displayedFields>
        <displayedFields>
            <field>PC_Rx_Start_Date__c</field>
            <isFieldManaged>false</isFieldManaged>
            <isRequired>false</isRequired>
        </displayedFields>
        <label>ACLS Document Link Prescription</label>
    </fieldSets>
    <fields>
        <fullName>ACLS_Engagement_Program_Code__c</fullName>
        <externalId>false</externalId>
        <label>Engagement Program Code</label>
        <length>100</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_Days_Supply__c</fullName>
        <deprecated>false</deprecated>
        <description>Number of days the prescribed medication will last if taken as per the recommended dosage.</description>
        <externalId>false</externalId>
        <label>Days Supply</label>
        <precision>3</precision>
        <required>false</required>
        <scale>0</scale>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_Document__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <deprecated>false</deprecated>
        <description>The documents associated with the prescription.</description>
        <label>Document</label>
        <referenceTo>PC_Document__c</referenceTo>
        <relationshipLabel>Prescriptions</relationshipLabel>
        <relationshipName>Prescriptions</relationshipName>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>PC_Dosage__c</fullName>
        <deprecated>false</deprecated>
        <description>The dosage of each drug in the prescription.</description>
        <externalId>false</externalId>
        <label>Dosage</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_Frequency__c</fullName>
        <deprecated>false</deprecated>
        <description>Frequency at which medication needs to be taken. For example, two times a day.</description>
        <externalId>false</externalId>
        <label>Frequency</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_Patient_Account__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <deprecated>false</deprecated>
        <description>The patient account associated with a specific prescription.</description>
        <label>Patient</label>
        <lookupFilter>
            <active>false</active>
            <filterItems>
                <field>Account.RecordType.DeveloperName</field>
                <operation>equals</operation>
                <value>PC_Patient</value>
            </filterItems>
            <isOptional>true</isOptional>
        </lookupFilter>
        <referenceTo>Account</referenceTo>
        <relationshipLabel>Prescriptions (Patient)</relationshipLabel>
        <relationshipName>Patient_Prescriptions</relationshipName>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>PC_Physician_Account__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <deprecated>false</deprecated>
        <description>The treating physician account associated with a specific prescription.</description>
        <label>Physician</label>
        <lookupFilter>
            <active>true</active>
            <errorMessage>Physician does not exist or is not a physician account</errorMessage>
            <filterItems>
                <field>Account.RecordType.DeveloperName</field>
                <operation>equals</operation>
                <value>PC_Physician</value>
            </filterItems>
            <isOptional>false</isOptional>
        </lookupFilter>
        <referenceTo>Account</referenceTo>
        <relationshipLabel>Prescriptions (Physician)</relationshipLabel>
        <relationshipName>Physician_Prescriptions</relationshipName>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>PC_PlaceOfService__c</fullName>
        <deprecated>false</deprecated>
        <description>Place of Service</description>
        <label>Place of Service</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>22</fullName>
                    <default>false</default>
                    <label>22: On Campus-Outpatient Hospita</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>PC_PrimaryDiagnosis__c</fullName>
        <deprecated>false</deprecated>
        <description>Primary Diagnosis Value</description>
        <label>Primary Diagnosis</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>M81.0</fullName>
                    <default>false</default>
                    <label>Age-related osteoporosis without current pathological fracture</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>PC_Product__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <deprecated>false</deprecated>
        <description>The drug associated with a specific prescription.</description>
        <label>Product</label>
        <referenceTo>Product2</referenceTo>
        <relationshipLabel>Prescriptions</relationshipLabel>
        <relationshipName>Prescriptions</relationshipName>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>PC_Program_Case__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <deprecated>false</deprecated>
        <description>The program case associated with a specific prescription.</description>
        <label>Program Case</label>
        <lookupFilter>
            <active>true</active>
            <booleanFilter>1</booleanFilter>
            <errorMessage>Program does not exist or is not a program case.</errorMessage>
            <filterItems>
                <field>Case.Type</field>
                <operation>equals</operation>
                <value>Program</value>
            </filterItems>
            <isOptional>false</isOptional>
        </lookupFilter>
        <referenceTo>Case</referenceTo>
        <relationshipLabel>Prescriptions</relationshipLabel>
        <relationshipName>Prescriptions</relationshipName>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>PC_Refills_Frequency__c</fullName>
        <deprecated>false</deprecated>
        <description>The formula used to calculate the refill frequency.</description>
        <externalId>false</externalId>
        <formula>IF(ISBLANK(PC_Rx_End_Date__c  -  PC_Rx_Start_Date__c),0,((PC_Rx_End_Date__c  -  PC_Rx_Start_Date__c) /  PC_Rx_Refills__c))</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Refills Frequency</label>
        <precision>18</precision>
        <required>false</required>
        <scale>2</scale>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_Requested_Quantity__c</fullName>
        <deprecated>false</deprecated>
        <description>Quantity of prescribed medication.</description>
        <externalId>false</externalId>
        <label>Requested Quantity</label>
        <precision>5</precision>
        <required>false</required>
        <scale>2</scale>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_Rx_End_Date__c</fullName>
        <deprecated>false</deprecated>
        <description>The date when the prescription expires.</description>
        <label>End Date</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>PC_Rx_Refills__c</fullName>
        <deprecated>false</deprecated>
        <description>Number of times refill of drugs needed.</description>
        <externalId>false</externalId>
        <label>Refills</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_Rx_Start_Date__c</fullName>
        <deprecated>false</deprecated>
        <description>The start date of the prescription.</description>
        <label>Start Date</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>PC_Rx_Status__c</fullName>
        <defaultValue>true</defaultValue>
        <deprecated>false</deprecated>
        <description>Status of the prescription (Checked means Active, Unchecked means Inactive)</description>
        <label>Is Active</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>PC_SecondaryDiagnosis__c</fullName>
        <deprecated>false</deprecated>
        <description>Secondary Diagnosis Value</description>
        <label>Secondary Diagnosis</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>M82.0</fullName>
                    <default>false</default>
                    <label>Age-related osteoporosis without current pathological fracture</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>PC_hasActivePA__c</fullName>
        <defaultValue>false</defaultValue>
        <deprecated>false</deprecated>
        <description>Checked when the prescription has an associated prior authorization.</description>
        <label>hasActivePA</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <label>Prescription</label>
    <listViews>
        <fullName>All</fullName>
        <columns>NAME</columns>
        <columns>PC_Patient_Account__c</columns>
        <columns>PC_Program_Case__c</columns>
        <columns>PC_Rx_Start_Date__c</columns>
        <columns>PC_Rx_End_Date__c</columns>
        <columns>PC_Rx_Status__c</columns>
        <columns>CREATED_DATE</columns>
        <filterScope>Everything</filterScope>
        <label>All</label>
    </listViews>
    <nameField>
        <displayFormat>Rx-{000000}</displayFormat>
        <label>Prescription Number</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Prescriptions</pluralLabel>
    <searchLayouts/>
    <sharingModel>Private</sharingModel>
    <validationRules>
        <fullName>PC_DuplicateCheckOfDiagnosis</fullName>
        <active>true</active>
        <description>The Primary and Secondary diagnosis fields cannot have same value</description>
        <errorConditionFormula>AND(
 TEXT(PC_PrimaryDiagnosis__c)  =  TEXT(PC_SecondaryDiagnosis__c),

  !ISBLANK(TEXT(PC_PrimaryDiagnosis__c)),
 !ISBLANK(TEXT(PC_SecondaryDiagnosis__c))
)</errorConditionFormula>
        <errorMessage>Prescription record cannot have same Primary and Secondary Diagnosis value</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
