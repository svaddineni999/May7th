    <validationRules>
        <fullName>PC_Program_Case_Validation</fullName>
        <active>true</active>
        <description>The Program Case lookup should only allow Program type of Cases</description>
        <errorConditionFormula>IF(OR(ISBLANK( PC_ProgramCase__c ), ISNULL(PC_ProgramCase__c )) , false, NOT(ISPICKVAL(PC_ProgramCase__r.Type, &apos;Program&apos;)))</errorConditionFormula>
        <errorDisplayField>PC_ProgramCase__c</errorDisplayField>
        <errorMessage>Only Program Cases allowed</errorMessage>
    </validationRules>
