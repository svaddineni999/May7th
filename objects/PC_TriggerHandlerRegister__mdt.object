        <type>TextArea</type>
    </fields>
    <fields>
        <fullName>PC_OrderOfExecution__c</fullName>
        <deprecated>false</deprecated>
        <externalId>false</externalId>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <inlineHelpText>Order in which trigger handlers should be executed. For example: 1 will be executed first, 2 will be executed next.</inlineHelpText>
