    <sharingModel>Private</sharingModel>
    <validationRules>
        <fullName>ACLS_Validate_Appeal_Outcome_Status</fullName>
        <active>true</active>
        <description>Case status for Appeal cannot be moved to Completed, unless Appeal Outcome is entered</description>
        <errorConditionFormula>IF(ISPICKVAL( Status , &apos;Completed&apos;) &amp;&amp; RecordType.DeveloperName == &apos;PC_Appeal&apos;&amp;&amp; ISPICKVAL( ACLS_Appeal_Outcome__c ,&apos;&apos; ),true,false)</errorConditionFormula>
        <errorMessage>Please enter Appeal Outcome in the Appeal Section</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>ACLS_Validate_DenialReason_Denied_Outcme</fullName>
        <active>true</active>
        <description>If Appeal Outcome = Denied, user needs to enter Denial Reason</description>
        <errorConditionFormula>IF( ISPICKVAL( ACLS_Appeal_Outcome__c , &apos;Denied&apos;) &amp;&amp; ISPICKVAL( PC_Denial_Reason__c ,&apos;&apos;),true,false)</errorConditionFormula>
        <errorMessage>Please select appropriate Denial reason</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>PC_Validate_Withdrawn_Date</fullName>
        <active>true</active>
        <errorConditionFormula>AND(  ISPICKVAL(Status , &apos;Withdrawn&apos;),  ISBLANK(TEXT(PC_Withdrawal_Date__c )))</errorConditionFormula>
        <errorDisplayField>PC_Withdrawal_Date__c</errorDisplayField>
        <errorMessage>Withdrawal Date is required  on Withdrawn</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>PC_Validate_Withdrawn_Reason</fullName>
        <active>true</active>
        <errorConditionFormula>AND( ISPICKVAL(Status , &apos;Withdrawn&apos;), ISBLANK( TEXT(PC_Reason_for_Withdrawal__c )))</errorConditionFormula>
        <errorDisplayField>PC_Reason_for_Withdrawal__c</errorDisplayField>
        <errorMessage>Reason for Withdrawal is required on Withdrawn</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Physician_Account_Record_Type_Validation</fullName>
        <active>true</active>
        <description>Rule to ensure that filter for Account field is respected</description>
        <errorConditionFormula>IF(OR(ISBLANK(PC_Physician__c),ISNULL(PC_Physician__c)), FALSE,   PC_Physician__r.RecordType.DeveloperName !=&apos;PC_Physician&apos;)</errorConditionFormula>
        <errorDisplayField>PC_Physician__c</errorDisplayField>
        <errorMessage>Account selected must be of the Record Type Physician</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Prescription_Program_and_Active_PA_Val</fullName>
        <active>true</active>
        <description>Rule to ensure that filter for Prescription field is respected</description>
        <errorConditionFormula>IF(OR( ISBLANK(PC_PA_Prescription__c),ISNULL( PC_PA_Prescription__c )),FALSE,OR(AND(PC_PA_Prescription__r.PC_hasActivePA__c == True,ISCHANGED(PC_PA_Prescription__c)), PC_PA_Prescription__r.PC_Program_Case__r.Id != PC_Program__r.Id))</errorConditionFormula>
        <errorDisplayField>PC_PA_Prescription__c</errorDisplayField>
        <errorMessage>Program Case on Prescription selected must match the Program Case of this Case and there should be no Active PA for the selected Prescription</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Product_Engagement_Program_Validation</fullName>
        <active>true</active>
        <description>Rule to ensure that filter for Product field is respected</description>
        <errorConditionFormula>IF(OR(ISBLANK(  PC_Program_Product__c),ISNULL(PC_Program_Product__c)), FALSE, PC_Program_Product__r.PC_Engagement_Program__r.Id != PC_Engagement_Program__r.Id)</errorConditionFormula>
        <errorDisplayField>PC_Program_Product__c</errorDisplayField>
        <errorMessage>Product selected must have Engagement Program same as this Program case</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Program_Case_Type_Validation</fullName>
        <active>true</active>
        <description>Rule to ensure that filter for Case field is respected</description>
        <errorConditionFormula>IF(OR(ISBLANK( PC_Program__c), ISNULL(PC_Program__c)), FALSE, NOT(ISPICKVAL(PC_Program__r.Type, &quot;Program&quot;)))</errorConditionFormula>
        <errorDisplayField>PC_Program__c</errorDisplayField>
        <errorMessage>Case selected must be of the type Program</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Program_Coverage_Program_ActivePA_Val</fullName>
        <active>true</active>
        <description>Rule to ensure that filter for Program Coverage field is respected</description>
        <errorConditionFormula>IF(OR(ISBLANK( PC_Program_Coverage__c ),ISNULL(PC_Program_Coverage__c )), FALSE, OR(PC_Program_Coverage__r.PC_Program__r.Id !=   PC_Program__r.Id ,  PC_Program_Coverage__r.PC_hasActivePA__c =true))</errorConditionFormula>
        <errorDisplayField>PC_Program_Coverage__c</errorDisplayField>
        <errorMessage>Program Case on Program Coverage selected must match the Program Case of this Case and there should be no Active PA with the selected Program Coverage</errorMessage>
    </validationRules>
    <webLinks>
        <fullName>HealthCloudGA__Apply_Care_Plan_Templates</fullName>
        <availability>online</availability>
