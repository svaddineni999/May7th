    <allowInChatterGroups>false</allowInChatterGroups>
    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <deploymentStatus>Deployed</deploymentStatus>
    <deprecated>false</deprecated>
    <description>Custom object to store Support Plan Activity Logs</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>false</enableReports>
    <enableSearch>false</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>Private</externalSharingModel>
    <fields>
        <fullName>PC_ActionRecordId__c</fullName>
        <deprecated>false</deprecated>
        <description>Id of record on which action is performed as part of Support plan Activity</description>
        <externalId>false</externalId>
        <label>Action Record Id</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_ActionRecordModifiedTime__c</fullName>
        <deprecated>false</deprecated>
        <description>Used to store Last modified Date Time of record on which action is performed using Support Plan</description>
        <label>Action Record Modified Time</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>DateTime</type>
    </fields>
    <fields>
        <fullName>PC_LogDateTime__c</fullName>
        <deprecated>false</deprecated>
        <description>Date/Time at which Support Plan Activity Log is logged or update</description>
        <label>Log Time</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>DateTime</type>
    </fields>
    <fields>
        <fullName>PC_RuntimeUser__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <deprecated>false</deprecated>
        <description>User who triggered the Support plan initiation</description>
        <label>Runtime User</label>
        <referenceTo>User</referenceTo>
        <relationshipName>PC_SupportPlanActivityLogs</relationshipName>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>PC_Status__c</fullName>
        <deprecated>false</deprecated>
        <description>Determines if the corresponding Support Plan Activity execution is in progress or completed.</description>
        <label>Status</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>In Progress</fullName>
                    <default>false</default>
                    <label>In Progress</label>
                </value>
                <value>
                    <fullName>Completed</fullName>
                    <default>false</default>
                    <label>Completed</label>
                </value>
                <value>
                    <fullName>Failed</fullName>
                    <default>false</default>
                    <label>Failed</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>PC_SupportPlanActivity__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <deprecated>false</deprecated>
        <description>Support Plan Activity using which the new Record is created</description>
        <label>Support Plan Activity</label>
        <referenceTo>PC_SupportPlanActivity__c</referenceTo>
        <relationshipLabel>Support Plan Activity Logs</relationshipLabel>
        <relationshipName>PC_SupportPlanActivityLogs</relationshipName>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>PC_SupportPlanRuntime__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <deprecated>false</deprecated>
        <description>Support Plan Runtime which was used to execute Support Plan Activity</description>
        <label>Support Plan Runtime</label>
        <referenceTo>PC_SupportPlanRuntime__c</referenceTo>
        <relationshipLabel>Support Plan Activity Logs</relationshipLabel>
        <relationshipName>PC_SupportPlanActivityLogs</relationshipName>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>PC_TransactionId__c</fullName>
        <deprecated>false</deprecated>
        <description>Unique ID generated for each transaction when Support Plan is initiated</description>
        <externalId>false</externalId>
        <label>Transaction Id</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_TriggerRecordId__c</fullName>
        <deprecated>false</deprecated>
        <description>Id of Record which triggered Support Plan</description>
        <externalId>false</externalId>
        <label>Trigger Record Id</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>Support Plan Activity Log</label>
    <listViews>
        <fullName>All</fullName>
        <columns>NAME</columns>
