    <fields>
        <fullName>PC_Account__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <deprecated>false</deprecated>
        <description>This field would be a lookup on Account record for which the Survey Invitation has ben created.</description>
        <label>Account</label>
        <referenceTo>Account</referenceTo>
