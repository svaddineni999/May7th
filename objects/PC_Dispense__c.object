    <externalSharingModel>Private</externalSharingModel>
    <fields>
        <fullName>PC_Dispensed_Date__c</fullName>
        <deprecated>false</deprecated>
        <description>The date on which the medication is dispensed.</description>
        <label>Dispensed Date</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>PC_Dispensed_Quantity__c</fullName>
        <deprecated>false</deprecated>
        <description>The quantity of dispensed medication.</description>
        <externalId>false</externalId>
        <label>Dispensed Quantity</label>
        <precision>18</precision>
        <required>false</required>
        <scale>2</scale>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
