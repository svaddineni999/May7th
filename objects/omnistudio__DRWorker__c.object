<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <customSettingsType>List</customSettingsType>
    <description>Each worker represents a possible Apex Batch Job that can be created at run time by the Vlocity Data Mapper service.  Use this to control the number of Data Mapper workers processing batches from the batch queue simultaneously.</description>
    <enableFeeds>false</enableFeeds>
    <fields>
        <fullName>omnistudio__Action__c</fullName>
        <deprecated>false</deprecated>
        <description>Action being performed</description>
        <externalId>false</externalId>
        <label>Action</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>omnistudio__ApexJobId__c</fullName>
        <deprecated>false</deprecated>
        <description>Job Id of this Worker</description>
        <externalId>false</externalId>
        <label>Apex Job Id</label>
        <length>20</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>omnistudio__DRBundleName__c</fullName>
        <deprecated>false</deprecated>
        <externalId>false</externalId>
        <label>Data Mapper Bundle Name</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>omnistudio__DRObjectName__c</fullName>
        <deprecated>false</deprecated>
        <description>Name of Data Mapper Object being processed currently.</description>
        <externalId>false</externalId>
        <label>Data Mapper Object Name</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>omnistudio__DRStatus__c</fullName>
        <deprecated>false</deprecated>
        <description>Status being processed</description>
        <externalId>false</externalId>
        <label>Data Mapper Status</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>omnistudio__StartedAt__c</fullName>
        <deprecated>false</deprecated>
        <description>Time when Data Mapper Batch Job began.</description>
        <label>Started At</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>DateTime</type>
    </fields>
    <label>Data Mapper Workers</label>
    <visibility>Public</visibility>
</CustomObject>
