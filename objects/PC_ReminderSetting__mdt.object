        <required>false</required>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Recipient Field API Name</fullName>
                    <default>true</default>
                    <label>Recipient Field API Name</label>
                </value>
                <value>
                    <fullName>Recipients Source Class</fullName>
                    <default>false</default>
                    <label>Recipient(s) Source Class</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
