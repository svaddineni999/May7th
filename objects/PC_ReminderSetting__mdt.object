    <fields>
        <fullName>PC_RecipientSource__c</fullName>
        <deprecated>false</deprecated>
        <description>Recipients will be retrieved while creating reminder queue based on the selection of this field. If Recipient Field API Name is chosen then the Recipient will be retrieved using Field API Name. Otherwise, Recipient
(s) Source Class will be executed to get recipients.</description>
