    <allowInChatterGroups>false</allowInChatterGroups>
    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <deploymentStatus>Deployed</deploymentStatus>
    <deprecated>false</deprecated>
    <description>*NOTE: No longer supported in Patient Connect since Spring &apos;18 release.* 
Custom object in Patient Connect that supports models which determine the tasks/activities to be provided to the patients related to a patient services program. The details about the support models are stored in this object.</description>
    <enableActivities>true</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableEnhancedLookup>true</enableEnhancedLookup>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>Private</externalSharingModel>
    <fields>
        <fullName>PC_Case_Type__c</fullName>
        <deprecated>false</deprecated>
        <description>Associates with the type of case that the support model is associated with.</description>
        <label>Case Type</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Program</fullName>
                    <default>false</default>
                    <label>Program</label>
                </value>
                <value>
                    <fullName>BI / BV</fullName>
                    <default>false</default>
                    <label>BI / BV</label>
                </value>
                <value>
                    <fullName>Alternate Funding</fullName>
                    <default>false</default>
                    <label>Alternate Funding</label>
                </value>
                <value>
                    <fullName>Appeal</fullName>
                    <default>false</default>
                    <label>Appeal</label>
                </value>
                <value>
                    <fullName>Copay</fullName>
                    <default>false</default>
                    <label>Copay</label>
                </value>
                <value>
                    <fullName>Prior Authorization</fullName>
                    <default>false</default>
                    <label>Prior Authorization</label>
                </value>
                <value>
                    <fullName>Problem</fullName>
                    <default>false</default>
                    <label>Problem</label>
                </value>
                <value>
                    <fullName>Feature Request</fullName>
                    <default>false</default>
                    <label>Feature Request</label>
                </value>
                <value>
                    <fullName>Question</fullName>
                    <default>false</default>
                    <label>Question</label>
                </value>
                <value>
                    <fullName>Access Service</fullName>
                    <default>false</default>
                    <label>Access Service</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>PC_Generate_All__c</fullName>
        <defaultValue>false</defaultValue>
        <deprecated>false</deprecated>
        <description>Indicates if support model activities should be generated all at once.</description>
        <label>Generate All</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>PC_Status__c</fullName>
        <deprecated>false</deprecated>
        <description>Determines if the support model is active or inactive for use.</description>
        <label>Status</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetName>PC_Status</valueSetName>
        </valueSet>
    </fields>
    <label>Support Model</label>
    <nameField>
        <label>Name</label>
        <type>Text</type>
    </nameField>
    <pluralLabel>Support Model</pluralLabel>
    <searchLayouts>
        <customTabListAdditionalFields>PC_Case_Type__c</customTabListAdditionalFields>
