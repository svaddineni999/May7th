<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>This is used to define the members of a group</description>
    <fields>
        <fullName>PC_Active__c</fullName>
        <defaultValue>false</defaultValue>
        <deprecated>false</deprecated>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Active</label>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>PC_FieldName__c</fullName>
        <deprecated>false</deprecated>
        <externalId>false</externalId>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <inlineHelpText>This field will contain field API Name or developer name without namespaceprefix. In case of standard field such as Record Type Field Name would be RecordType only.</inlineHelpText>
        <label>Field Name</label>
        <length>255</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_FieldValue__c</fullName>
        <deprecated>false</deprecated>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <inlineHelpText>This field will store field value which needs to be grouped . In case of standard field such as RecordType it would be qualified api name i.e. recordtype with namespaceprefix.</inlineHelpText>
        <label>Field Value</label>
        <required>false</required>
        <type>TextArea</type>
    </fields>
    <fields>
        <fullName>PC_Field_Namespace__c</fullName>
        <deprecated>false</deprecated>
        <externalId>false</externalId>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Field Namespace</label>
        <length>255</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_Group__c</fullName>
        <deprecated>false</deprecated>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Group</label>
        <referenceTo>PC_Group__mdt</referenceTo>
        <relationshipLabel>Group Members</relationshipLabel>
        <relationshipName>Groups</relationshipName>
        <required>false</required>
        <type>MetadataRelationship</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_ObjectName__c</fullName>
        <deprecated>false</deprecated>
        <externalId>false</externalId>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <inlineHelpText>This Field will store the API Name of Object i.e. Developer Name without Namespace</inlineHelpText>
        <label>Object Name</label>
        <length>255</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_Object_Namespace__c</fullName>
        <deprecated>false</deprecated>
        <externalId>false</externalId>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <inlineHelpText>This field will store namespace prefix associated with the Sobject name.</inlineHelpText>
        <label>Object Namespace</label>
        <length>255</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>Group Member</label>
    <pluralLabel>Group Members</pluralLabel>
    <visibility>Public</visibility>
</CustomObject>
