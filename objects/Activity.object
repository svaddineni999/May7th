    <fields>
        <fullName>PC_Priority_Value__c</fullName>
        <deprecated>false</deprecated>
        <description>Value associated with the acticity based on the priority.</description>
        <externalId>false</externalId>
        <formula>IF(text(Priority) = &apos;High&apos;,10,IF(text(Priority) = &apos;Normal&apos;,20,30))</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <inlineHelpText>Value associated with the acticity based on the priority.</inlineHelpText>
        <label>Priority Value</label>
        <precision>18</precision>
        <required>false</required>
