    <sharingModel>ControlledByParent</sharingModel>
    <startsWith>Vowel</startsWith>
    <validationRules>
        <fullName>Validate_end_date</fullName>
        <active>true</active>
        <errorConditionFormula>OR( 
AND(NOT(ISBLANK(PC_End_Date__c)), PC_End_Date__c &lt; PC_Start_Date__c),
AND( ISPICKVAL(PC_Status__c, &apos;Inactive&apos;), ISBLANK(PC_End_Date__c))
)</errorConditionFormula>
        <errorMessage>End Date cannot predate Start Date
End Date cannot be blank if Status = Inactive</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
