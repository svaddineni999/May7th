    </fields>
    <fields>
        <fullName>PC_Complete_Address__c</fullName>
        <deprecated>false</deprecated>
        <description>The full address populated from the individual address lines.</description>
        <externalId>false</externalId>
        <formula>IF(ISBLANK(PC_Address_1__c ),  &apos;&apos; ,  PC_Address_1__c) +
IF(ISBLANK(PC_City__c ), &apos;&apos; , &apos;, &apos; + PC_City__c )+
IF(ISBLANK(TEXT(PC_State__c)  ) , &apos;&apos; , &apos;, &apos; + TEXT(PC_State__c))+
IF(ISBLANK(PC_Zip_Code__c) ,&apos;&apos; , &apos;, &apos; + PC_Zip_Code__c)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Complete Address</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
