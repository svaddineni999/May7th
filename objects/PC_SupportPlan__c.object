        <label>Support Plan Name</label>
        <type>Text</type>
    </nameField>
    <pluralLabel>Support Plans</pluralLabel>
    <searchLayouts/>
    <sharingModel>ReadWrite</sharingModel>
    <validationRules>
        <fullName>PC_Avoid_DuplicateName</fullName>
        <active>true</active>
        <errorConditionFormula>and(
    Name = VLOOKUP
       ($ObjectType.PC_SupportPlan__c.Fields.Name , $ObjectType.PC_SupportPlan__c.Fields.Name, Name ),

    not(
     Id=VLOOKUP
         ($ObjectType.PC_SupportPlan__c.Fields.Id , $ObjectType.PC_SupportPlan__c.Fields.Name, Name )))</errorConditionFormula>
        <errorDisplayField>Name</errorDisplayField>
        <errorMessage>Support Plan name already exists, please choose a different name.</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
