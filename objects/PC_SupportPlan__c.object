                <value>
                    <fullName>Conditional Builder</fullName>
                    <default>false</default>
                    <label>Conditional Builder</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>PC_TriggerEventCondition__c</fullName>
        <deprecated>false</deprecated>
        <description>Stores the Trigger condition logic in JSON Format</description>
        <label>Condition</label>
        <length>131072</length>
        <trackTrending>false</trackTrending>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
    <fields>
        <fullName>PC_TriggerEventConditionalBehavior__c</fullName>
        <deprecated>false</deprecated>
        <description>Indicates how the Trigger Event Condition should be treated:
-Wait Until True: The Support plan will stay on the current activity till Trigger Event Condition is met.
-No Condition: There is no condition and hence Support plan can be created/executed.</description>
        <label>Conditional Behavior</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>No Condition</fullName>
                    <default>false</default>
                    <label>No Condition</label>
                </value>
                <value>
                    <fullName>Wait until True</fullName>
                    <default>false</default>
                    <label>Wait until True</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>PC_TriggerEventObject__c</fullName>
        <deprecated>false</deprecated>
        <description>API Name of Object on which  Support plan is Run</description>
        <externalId>false</externalId>
        <label>Object</label>
        <length>255</length>
