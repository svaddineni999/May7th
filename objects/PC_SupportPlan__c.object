    <deploymentStatus>Deployed</deploymentStatus>
    <deprecated>false</deprecated>
    <description>Custom object in Patient Connect that helps to create a predefined template of activities (tasks and events) according to the type of case and the brands that are supported.</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>false</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>Private</externalSharingModel>
    <fields>
        <fullName>PC_ConditionBehavior__c</fullName>
        <deprecated>false</deprecated>
        <description>Indicates how the Start Condition should be treated: 
 -Wait Until True: The Support Plan will stay on the current activity unless a Start Condition is met.
 -No Condition: There is no condition on the Support Plan activity and hence can be created/executed.</description>
        <label>Condition Behavior</label>
        <required>true</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>No Condition</fullName>
                    <default>true</default>
                    <label>No Condition</label>
                </value>
                <value>
                    <fullName>Wait until True</fullName>
                    <default>false</default>
                    <label>Wait until True</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>PC_Condition_Option__c</fullName>
        <deprecated>false</deprecated>
        <label>Condition Option</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Apex Class</fullName>
                    <default>false</default>
                    <label>Apex Class</label>
                </value>
                <value>
                    <fullName>Conditional Builder</fullName>
                    <default>false</default>
                    <label>Condition Builder</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>PC_Conditional_Logic__c</fullName>
        <deprecated>false</deprecated>
        <description>JSON string containing the conditional rows</description>
        <label>Conditional Logic</label>
        <length>32768</length>
        <trackTrending>false</trackTrending>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
    <fields>
        <fullName>PC_Description__c</fullName>
        <deprecated>false</deprecated>
        <description>Provides a brief description about Support Plan.</description>
        <inlineHelpText>Description of Support Plan</inlineHelpText>
        <label>Description</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>TextArea</type>
    </fields>
    <fields>
        <fullName>PC_InitialActivity__c</fullName>
        <deprecated>false</deprecated>
        <description>Indicates if an activity is the first activity of a Support Plan. References &apos;Internal Activity Number&apos;.</description>
        <externalId>false</externalId>
        <label>Initial Activity</label>
        <length>80</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_IsActive__c</fullName>
        <defaultValue>false</defaultValue>
        <deprecated>false</deprecated>
        <description>Indicates if the Support Plan is active.</description>
        <label>Is Active</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>PC_StartCondition__c</fullName>
        <deprecated>false</deprecated>
        <description>Indicates the condition that must be evaluated before a Support Plan is initiated.</description>
        <externalId>false</externalId>
        <inlineHelpText>Condition that needs to be met to initiate Support Plan</inlineHelpText>
        <label>Start Condition</label>
        <length>250</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_SupportPlan_Behavior__c</fullName>
        <deprecated>false</deprecated>
        <description>This describes the behavior of the Support Plan. Note - If the value is blank, then the behavior is assumed to be &apos;RunEveryTimeRuleMatches&apos; by default.</description>
        <inlineHelpText>Would you like to run this Support Plan every time the conditions are met for a record?</inlineHelpText>
        <label>Support Plan Runtime Behavior</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>RunEveryTimeRuleMatches</fullName>
                    <default>true</default>
                    <label>Yes, run this Support Plan every time the conditions are met.</label>
                </value>
                <value>
                    <fullName>RunOncePerRecord</fullName>
                    <default>false</default>
                    <label>No, run this Support Plan only once per record.</label>
                </value>
                <value>
                    <fullName>RunEveryTimeIfNoPendingRuntime</fullName>
                    <default>false</default>
                    <label>No, run this Support Plan only when there are no pending activities from previous Support Plan Runtime(s).</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>PC_TriggerEventConditionOption__c</fullName>
        <deprecated>false</deprecated>
        <description>Indicates the type of option to evaluate trigger condition</description>
        <label>Condition Option</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
