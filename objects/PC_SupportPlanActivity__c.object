        <fullName>PC_ConditionBehavior__c</fullName>
        <deprecated>false</deprecated>
        <description>Indicates how the Start Condition should be treated: 
 -Wait Until True: The Support Plan will stay on the current activity unless a Start Condition is met.
 -No Condition: There is no condition on the Support Plan activity and hence can be created/executed.</description>
        <label>Condition Behavior</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>No Condition</fullName>
                    <default>true</default>
                    <label>No Condition</label>
                </value>
                <value>
                    <fullName>Wait until True</fullName>
                    <default>false</default>
                    <label>Wait until True</label>
                </value>
                <value>
                    <fullName>Skip if False</fullName>
                    <default>false</default>
                    <label>Skip if False</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
