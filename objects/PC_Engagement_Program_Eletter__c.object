            {&quot;name&quot; : &quot;David&quot;,&quot;Phone&quot; : &quot;+919897898789&quot;,&quot;role&quot;:&quot;Specialist&quot;}]</inlineHelpText>
        <label>Pre Configured SMS Recipients</label>
        <length>131072</length>
        <trackTrending>false</trackTrending>
