    <fields>
        <fullName>PC_PreConfiguredEmailRecipients__c</fullName>
        <deprecated>false</deprecated>
        <description>Pre configured email recipients for sending Adverse Event report via email and to show non-case role users as recipients for e-letter. Please add mail ids as comma separated values and with no spaces. Ex-abc@xyz.com,xyz@abc.com.

JSON format as shown below can also be provided when used for non-case role users as recipients for e-letter.
Ex. [{&quot;name&quot; : &quot;Linda&quot;, &quot;email&quot; : &quot;user1@test.com&quot;, &quot;fax&quot; : &quot;9878787678&quot;,&quot;role&quot;:&quot;Nurse&quot;},
{&quot;name&quot; : &quot;David&quot;, &quot;email&quot; : &quot;user2@test.com&quot;, &quot;fax&quot; : &quot;9897898789&quot;,&quot;role&quot;:&quot;Dentist&quot;}]</description>
        <inlineHelpText>Recipients for sending Adverse Event report via email and to show non-case role users as recipients for e-letter. Please add mail ids as comma separated values and with no spaces. Ex-abc@xyz.com,xyz@abc.com. See description for more details.</inlineHelpText>
        <label>Pre Configured Email Recipients</label>
        <length>131072</length>
        <trackTrending>false</trackTrending>
        <type>LongTextArea</type>
        <visibleLines>4</visibleLines>
    </fields>
    <fields>
        <fullName>PC_PreConfiguredSMSRecipients__c</fullName>
        <deprecated>false</deprecated>
        <description>External recipients for sending SMS. Please add phone numbers in JSON format as shown in the example,

            Ex. [{&quot;name&quot; : &quot;Linda&quot;,&quot;Phone&quot; : &quot;+15671112230&quot;,&quot;role&quot;:&quot;Nurse&quot;},
            {&quot;name&quot; : &quot;David&quot;,&quot;Phone&quot; : &quot;+919897898789&quot;,&quot;role&quot;:&quot;Specialist&quot;}]</description>
        <inlineHelpText>External recipients for sending SMS .Please add phone numbers in JSON format as shown in the example,

