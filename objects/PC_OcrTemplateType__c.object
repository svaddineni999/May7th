    <searchLayouts/>
    <sharingModel>ReadWrite</sharingModel>
    <validationRules>
        <fullName>PC_AvoidSpecialCharacters</fullName>
        <active>true</active>
        <errorConditionFormula>NOT(REGEX(  PC_APIName__c ,&quot;^[A-Za-z](?:_?[A-Za-z0-9]+)*$&quot;))</errorConditionFormula>
        <errorDisplayField>PC_APIName__c</errorDisplayField>
        <errorMessage>The OCR Template Type name can only contain alphanumeric characters, must begin with a letter, cannot end with an underscore or contain two consecutive underscore characters, and must be unique across all Template Type names.</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
