    <fields>
        <fullName>PC_CoinsuranceApplies__c</fullName>
        <deprecated>false</deprecated>
        <description>Indicates if the coinsurance amount applies to the patient.  The status types are:
• Yes: If the coinsurance amount applies
•  No: If the coinsurance amount does not apply.
•  Undetermined: If the coinsurance amount  cannot be determined.
•  N/A: If the coinsurance amount is not applicable.</description>
        <label>CoinsuranceApplies</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Yes</fullName>
                    <default>false</default>
                    <label>Yes</label>
                </value>
                <value>
                    <fullName>No</fullName>
                    <default>false</default>
                    <label>No</label>
                </value>
                <value>
                    <fullName>Undetermined</fullName>
                    <default>false</default>
                    <label>Undetermined</label>
                </value>
                <value>
                    <fullName>N/A</fullName>
                    <default>false</default>
                    <label>N/A</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>PC_CoinsurancePercent__c</fullName>
        <deprecated>false</deprecated>
        <description>Coinsurance Amount in percent</description>
        <inlineHelpText>Coinsurance Amount in percent</inlineHelpText>
        <label>Coinsurance Percent</label>
        <precision>5</precision>
        <required>false</required>
        <scale>2</scale>
        <trackHistory>false</trackHistory>
        <type>Percent</type>
    </fields>
