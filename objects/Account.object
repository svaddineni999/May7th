    <fields>
        <fullName>ACLS_Age__c</fullName>
        <externalId>false</externalId>
        <formula>IF( (NOT( ISBLANK( PC_Date_of_Birth__c)) &amp;&amp; NOT( PC_Date_of_Birth__c &gt;TODAY())) , TEXT(IF( NOT( ISBLANK( PC_Date_of_Birth__c) ) ,
IF( DATE( 2000 , MONTH( PC_Date_of_Birth__c) , DAY( PC_Date_of_Birth__c) ) &lt;= DATE( 2000 , MONTH( TODAY() ) , DAY( TODAY() ) ),
YEAR (Today()) - YEAR ( PC_Date_of_Birth__c),
YEAR (Today()) - YEAR ( PC_Date_of_Birth__c) -1 ),
null))+ &apos; Years &apos;, &apos;&apos;)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Age</label>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
