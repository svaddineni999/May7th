<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>To store Engagement Programs with their program code.</description>
    <fields>
        <fullName>ACLS_Campaign_Name__c</fullName>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Campaign Name</label>
        <length>255</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_Description__c</fullName>
        <deprecated>false</deprecated>
        <description>Description of the Engagement Program</description>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <inlineHelpText>Description of the Engagement Program</inlineHelpText>
        <label>Description</label>
        <required>false</required>
        <type>TextArea</type>
    </fields>
    <fields>
        <fullName>PC_EngagementProgramCode__c</fullName>
        <deprecated>false</deprecated>
        <description>Holds Engagement Program Code specified in the Engagement Program object</description>
        <externalId>false</externalId>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <inlineHelpText>Holds Engagement Program Code specified in the Engagement Program object</inlineHelpText>
        <label>Engagement Program Code</label>
        <length>10</length>
        <required>true</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>PC_IsActive__c</fullName>
        <defaultValue>false</defaultValue>
        <deprecated>false</deprecated>
        <description>Specifies whether the Engagement Program is active. Note that making it as inactive may render the associated setting also as inactive.</description>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <inlineHelpText>Specifies whether the Engagement Program is active. Note that making it as inactive may render the associated setting also as inactive.</inlineHelpText>
        <label>Is Active</label>
        <type>Checkbox</type>
    </fields>
    <label>Engagement Program</label>
    <pluralLabel>Engagement Programs</pluralLabel>
    <visibility>Public</visibility>
</CustomObject>
