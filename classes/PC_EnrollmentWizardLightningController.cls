     * Wrapper for the enrollment case that is provided to all wizard pages.
     */
    public inherited sharing class EnrollmentCaseWrapper {
        @AuraEnabled public Id enrollmentId {get;set;}
        @AuraEnabled public Id accountId {get; set;}
        @AuraEnabled public String accountName {get; set;}
        @AuraEnabled public String enrollmentNumber {get; set;}
        @AuraEnabled public String enrollmentStatus {get; set;}
        @AuraEnabled public String recordTypeName {get; set;}
        @AuraEnabled public DateTime enrollmentCreatedDate {get; set;}
        @AuraEnabled public DateTime enrollmentClosedDate {get; set;}
        @AuraEnabled public String engagementProgram {get; set;}
        @AuraEnabled public String wizardState {get; set;}
		@AuraEnabled public Id applicantId {get;set;}
        @AuraEnabled public String applicantType {get; set;}
        @AuraEnabled public Boolean isOnlineApplicant {get; set;}
                
        public EnrollmentCaseWrapper(Case c) {
            enrollmentId = c.Id;
            accountId = c.AccountId;
            accountName = c.Account.Name;
            enrollmentNumber = c.CaseNumber;
            enrollmentStatus = c.Status;
            recordTypeName = c.RecordType.Name;
			enrollmentCreatedDate = c.CreatedDate;
            enrollmentClosedDate = c.ClosedDate;
			engagementProgram = c.PC_Engagement_Program__r.Name;
            wizardState = c.PC_EnrollmentWizardState__c;
            
        }     
    }
    
    /**
     * Wrapper for the enrollment wizard setup. Includes all information needed to initialize the
     * wizard.
     */
    public inherited sharing class EnrollmentWizardWrapper {
        @AuraEnabled public EnrollmentCaseWrapper enrollmentCase {get; set;}
        @AuraEnabled public List<PageMetadataWrapper> lstPageMetadata {get; set;}
        @AuraEnabled public Id enrollmentCaseId {get; set;}

        public EnrollmentWizardWrapper() {
            lstPageMetadata = new List<PageMetadataWrapper>();
        }
    }

	@TestVisible
    private static List<PC_EnrollmentWizardPage__mdt> getEnrollmentWizardPages(String programCode) {
        return [SELECT Id, DeveloperName, MasterLabel, NamespacePrefix,
                    Label, QualifiedApiName, PC_ComponentName__c, PC_EnrollmentWizardPageLabel__c, PC_Ordinal__c, PC_Config2__c,
                    PC_Processor__c, PC_Config__C
            FROM PC_EnrollmentWizardPage__mdt
            WHERE PC_ProgramCode__c = :programCode AND PC_Active__c = TRUE
            ORDER BY PC_Ordinal__c ASC];
    }

    /**
     * Returns the enrollment case for the case ID provided.
     *
     * @param   enrollmentCaseId    The Id of the enrollment case to retrieve.
     */
    private static Case getEnrollmentCase(Id enrollmentCaseId) {
    	/*
        * FLS Check for Case
        */
    	List<String> fields = new List<String>{'AccountId','ClosedDate', 'Origin', PC_Constants.getQualifiedAPIName('PC_Document__c'),
    											PC_Constants.getQualifiedAPIName('PC_Program__c'), PC_Constants.getQualifiedAPIName('PC_EnrollmentWizardState__c'),
    											PC_Constants.getQualifiedAPIName('PC_ActiveApplicant__c'), PC_Constants.getQualifiedAPIName('PC_Engagement_Program__c')};
        PC_Database.assertAccess(PC_Constants.PC_CASE, PC_Database.Operation.Reading, fields);
        /*
        * FLS Check for PC_Engagement_Program__c
        */
    	fields = new List<String>{'Name',PC_Constants.getQualifiedAPIName('PC_Program_Code__c'), PC_Constants.getQualifiedAPIName('PC_Manufacturer__c')};
        PC_Database.assertAccess(PC_Constants.getQualifiedAPIName('PC_Engagement_Program__c'), PC_Database.Operation.Reading, fields);
        /*
        * FLS Check for Account
        */
        fields = new List<String>{'Name'};
        PC_Database.assertAccess(PC_Constants.PC_ACCOUNT, PC_Database.Operation.Reading, fields);

        return [SELECT Id, AccountId, Account.Name, CaseNumber, Status, RecordType.Name, CreatedDate, ClosedDate, Origin,
                PC_Program__c, PC_EnrollmentWizardState__c, PC_ActiveApplicant__c,
                PC_Engagement_Program__r.Name, PC_Engagement_Program__r.PC_Program_Code__c, PC_Engagement_Program__r.PC_Manufacturer__c, PC_Program__r.Id
                FROM Case 
                WHERE Id =: enrollmentCaseId LIMIT 1];
    }
    
    /**
     * Returns the applicant assocciated with the enrollment case for the case ID provided.
     *
     * @param   enrollmentCaseId    The Id of the enrollment case for the applicant to retrieve.
     */
    private static List <PC_Applicant__c> getApplicant(Id applicantId) {
        return [SELECT Id, RecordType.Name FROM PC_Applicant__c 
                WHERE Id =: applicantId];  
    }
