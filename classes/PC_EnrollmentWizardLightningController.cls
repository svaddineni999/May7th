    /**
     * Method to setup enrollment wizard page metadata for the engagement program associated with the enrollment case.
     * enrollmentCaseId is used to retrieve assocaited engagement program, patient account, applicant id 
     * and enrollment wizard state   
     */
    @AuraEnabled
    public static EnrollmentWizardWrapper setupEnrollmentWizard(Id enrollmentCaseId) {
        EnrollmentWizardWrapper enrollmentWrapper = new EnrollmentWizardWrapper();
        try {
            if(!PC_Utility.hasHealthCloudPermissionSetAssigned()) {
                PC_Utility.throwAuraHandledException(Label.PC_HC_PermissionSet_Missing);
            }
            Case enrollmentCase = getEnrollmentCase(enrollmentCaseId);
            enrollmentWrapper.enrollmentCase = new EnrollmentCaseWrapper(enrollmentCase);
            List <PC_Applicant__c> applicant = getApplicant(enrollmentCase.PC_ActiveApplicant__c);           
            if(!applicant.isEmpty()) { 
                enrollmentWrapper.enrollmentCase.applicantId = applicant[0].Id;
                enrollmentWrapper.enrollmentCase.applicantType = applicant[0].RecordType.Name; 
                if(PC_Constants.APPLICANT_ONLINE_RECORD_TYPE_NAME.equalsIgnoreCase(enrollmentWrapper.enrollmentCase.applicantType)) {
                    enrollmentWrapper.enrollmentCase.isOnlineApplicant = true;
                }
                else {
                    enrollmentWrapper.enrollmentCase.isOnlineApplicant = false;
                }                
            }
            else {
                enrollmentWrapper.enrollmentCase.isOnlineApplicant = false;
            }

            List<PC_EnrollmentWizardPage__mdt> pageMetadata = getEnrollmentWizardPages(enrollmentCase.PC_Engagement_Program__r.PC_Program_Code__c);
        	for (PC_EnrollmentWizardPage__mdt a : pageMetadata) {
                enrollmentWrapper.lstPageMetadata.add(new PageMetadataWrapper(a));
            }    
            
            System.debug(JSON.serialize(enrollmentWrapper.lstPageMetadata));
        } catch(Exception ex) {
            PC_Utility.logAndThrowException(ex);
        }
        
        return enrollmentWrapper;
    }
    
    /**
     * Method to save current enrollment wizard state   
     */
    @AuraEnabled
    public static void saveWizardState(Id enrollmentCaseId, String wizardState) {
    	try {
            List<String> fields = new List<String> {'CaseNumber', PC_Constants.getQualifiedAPIName('PC_EnrollmentWizardState__c')};
            PC_Database.assertAccess(PC_Constants.PC_CASE, PC_Database.Operation.Reading, fields);
            Case enrollmentCase = [SELECT CaseNumber, PC_EnrollmentWizardState__c FROM Case WHERE Id =: enrollmentCaseId LIMIT 1];
			enrollmentCase.PC_EnrollmentWizardState__c = wizardState;
            PC_Database.upd(enrollmentCase,true);
        
        } catch(Exception ex) {
            PC_Utility.logAndThrowException(ex);
        }
    }

    /**
     * Performs enrollment processing after all wizard pages have been completed.
     *
     * @param enrollmentCaseId  The Id of the enrollment case that the wizard is associated with.
     */
    @AuraEnabled
    public static EnrollmentProcessingResult processEnrollment(Id enrollmentCaseId) {
        
        Case enrollmentCase = getEnrollmentCase(enrollmentCaseId);
        List<PC_EnrollmentWizardPage__mdt> pageMetadata = getEnrollmentWizardPages(enrollmentCase.PC_Engagement_Program__r.PC_Program_Code__c);
        
        Map<String, Object> pageAttributeMap = (Map<String, Object>) JSON.deserializeUntyped(enrollmentCase.PC_EnrollmentWizardState__c);
        EnrollmentProcessingResult result = new EnrollmentProcessingResult();
        Savepoint sp = Database.setSavepoint();

        try {
            for (PC_EnrollmentWizardPage__mdt page : pageMetadata) {
                
                result.errorPageDeveloperName = page.DeveloperName;
                String processorName = page.PC_Processor__c;
                
                if (processorName == null) {
                    processorName = page.PC_ComponentName__c + 'Processor';
                    if(processorName.contains(':')){
                        List<String> splitString = processorName.split(':');
                        String LHS = splitString[0];
                        String RHS = splitString[1];
                        If(LHS.toLowerCase() == 'c') {
                            processorName = RHS;
                        }else{
                            processorName = processorName.replace(':','.');
                        }
                    }
                }
                Type t = Type.forName(processorName);
                
                if (t != null) {
                	
                    Object o = t.newInstance();

                    if (o instanceof PC_EnrollmentWizard.PageProcessor) {
                        PC_EnrollmentWizard.PageProcessor processor = (PC_EnrollmentWizard.PageProcessor) o;
                        Map<String, Object> pageState = (Map<String, Object>) pageAttributeMap.get(page.DeveloperName);
                        
                        processor.processEnrollment(enrollmentCase, pageState);
                    }else {
                        PC_EnrollmentWizard.PageProcessorException e = new PC_EnrollmentWizard.PageProcessorException(
                            'Processor: ' + processorName + ' found, but does not implement required interface');
                        e.setUserMessage(Label.PC_EW_Configuration_Error);
                    }
                } else {
                    System.debug('No wizard page processor found for page: ' + page.PC_ComponentName__c);
                }
            }

            result.userMessages = PC_EnrollmentWizard.getUserMessage();
            enrollmentCase.Status = PC_Constants.COMPLETED;
            PC_EnrollmentWizard.addToRecordsToBeUpdated(enrollmentCase);
            //PC_Database.upd(enrollmentCase);
            PC_Database.upd(PC_EnrollmentWizard.getRecordsToBeUpdated());
            result.success = true;
            result.programCase = enrollmentCase.PC_Program__c;
        } catch (PC_EnrollmentWizard.PageProcessorException e) {
            Database.rollback(sp);
            PC_Utility.createExceptionLog(e);
            
            result.errorMessage = e.getUserMessage();
            result.userRecoverable = e.isUserRecoverable();
            
            if (result.errorMessage == null) {
                result.errorMessage = e.getMessage();
            }
        } catch (System.NoAccessException e) {
			Database.rollback(sp);
            PC_Utility.createExceptionLog(e);
            result.errorMessage = e.getMessage();
			
		} catch (System.DmlException e) {
			Database.rollback(sp);
            PC_Utility.createExceptionLog(e);
            String dmlErrorMessage = System.Label.PC_DML_Error_Message;
           	for (Integer i = 0; i < e.getNumDml(); i++) {
				// Process exception here
				result.errorMessage = dmlErrorMessage +e.getDmlMessage(i);
			}
		} catch (Exception e) {
            Database.rollback(sp);
            PC_Utility.createExceptionLog(e);
            String generalErrorMessage = System.Label.PC_General_Error_Message;
            generalErrorMessage	= generalErrorMessage.replace('{vTypeName}', e.getTypeName());
            generalErrorMessage	= generalErrorMessage.replace('{vMessage}', e.getMessage());
            result.errorMessage = generalErrorMessage;
        }
        return result;
    }

    /**
     * Wrapper for the enrollment processing results;
     */
    public inherited sharing class EnrollmentProcessingResult {
        /**
         * Specifies if the enrollment processing completed successfully or not.
         */
        @AuraEnabled public Boolean success {get;set;}

        /**
         * Specifies if the enrollment processing error can potentially be resolved by user action.
         */
        @AuraEnabled public Boolean userRecoverable {get;set;}

        /**
         * The developer name of the wizard page where the enrollment processing error occurred.
         */
        @AuraEnabled public String errorPageDeveloperName {get;set;}

        /**
         * The error message to display to the user in the enrollment wizard.
         */
        @AuraEnabled public String errorMessage {get;set;}

        /**
         * The error message to display to the user in the enrollment wizard.
         */
        @AuraEnabled public List<PC_EnrollmentWizard.UserMessage> userMessages {get;set;}

        /**
         * The Program Case Created after Enrollment Success.
         */
        @AuraEnabled public String programCase {get;set;}
        /**
         * Custom Component to be shown on successful enrollment
         */
        @AuraEnabled public String enrollConfirmCustomComponent {get; set;}
        /**
         * Default Component to be shown if Custom Component is blank or fails
         */
        @AuraEnabled public String enrollConfirmDefaultComponent {get {return defaultComponent;}}

        private final string defaultComponent = PC_Constants.OrgNamespace + ':' + 'PC_EnrollConfirm';
        private final string enrollConfirmSettingName = 'PC_EnrollConfirmComponent';

        public EnrollmentProcessingResult() {
            success = false;
            enrollConfirmCustomComponent = PC_SYSTEM.getPatientConnectSetting(enrollConfirmSettingName, defaultComponent);
        }
    }
    
    /**
     * Wrapper for the custom page metadata type.
     */
    public inherited sharing class PageMetadataWrapper {
        @AuraEnabled public Id pageId {get;set;}
        @AuraEnabled public String developerName {get; set;}
        @AuraEnabled public String masterLabel {get; set;}
        @AuraEnabled public String namespacePrefix {get; set;}
        @AuraEnabled public String label {get; set;}
        @AuraEnabled public String qualifiedApiName {get; set;}
        @AuraEnabled public String componentName {get; set;}
        @AuraEnabled public String config {get; set;}
        @AuraEnabled public Decimal ordinal {get; set;}

        public PageMetadataWrapper(PC_EnrollmentWizardPage__mdt c) {
            pageId = c.Id;
            developerName = c.DeveloperName;
            masterLabel = c.MasterLabel;
            namespacePrefix = c.NamespacePrefix;
            // [PC-6786] label and masterLabel in wrapper are holding same label value.
            // Instead of creating new property, using this label property for new label field (PC_EnrollmentWizardPageLabel__c)
            label = c.PC_EnrollmentWizardPageLabel__c;
            qualifiedApiName = c.QualifiedApiName;
            componentName = (c.PC_ComponentName__c.contains(':')) ? c.PC_ComponentName__c : 'c:' + c.PC_ComponentName__c;
            config = String.isNotBlank(c.PC_Config2__c) ? c.PC_Config2__c : c.PC_Config__c;
            ordinal = c.PC_Ordinal__c;
        }
    }
   
