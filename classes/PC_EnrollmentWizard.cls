/**
 * The  PC_EnrollmentWizard class contains the PageProcessor interface implemented
 * by enrollment wizard pages for performing server side object creation, along
 * with the PageProcessorException that can be thrown by a PageProcessors.
 */
global inherited sharing class PC_EnrollmentWizard {
    /**
     * The PageProcessor interface is implemented by enrollment wizard pages
     * that need to perform server side processing during the final enrollment
     * step of the enrollment wizard.
     *
     * Processors that follow a naming convention of
     * <EnrollmentWizardPage>Process, where <EnrollmentWizardPage> is the name of
     * the auro component will be called automatically. If a different class name is
     * used, or if the interface is implemented by the controller, it can be specified
     * explicitly in the Enrollment Wizard Pages custom metadata record.
     */
    global interface PageProcessor {
        /**
         * Called by the enrollment wizard for each page in the wizard page flow.
         *
         * @param enrollmentCase The enrollment case that the wizard is collecting data for. It will
         *                       be automatically updated by the wizard after all page processors have
         *                       been executed.
         * @param pageState      A map of attributes that were defined by the "persisitentAttributes"
         *                       attribute in the client component.
         * @throws PageProcessorException If there is a validation or other processing error detected during processing.
         *                       The processor need not handle and wrap other excpetions, such as DMLExceptions
         *                       during processing, as these will be handled automatically by the wizard.
         */
        void processEnrollment(Case enrollmentCase, Map<String, Object> pageState);
    }

    /**
     * A PageProcessorException is thrown by PageProcessor.processEnrollment when a problem is encountered
     * that prevents the processor from completing its portion of the enrollment.
     */
	global inherited sharing class PageProcessorException extends Exception {
        boolean userRecoverable = false;
        String userMessage;

        /**
         * Sets the user recoverability of the exception.PageProcessorException
         *
         * @param userRecoverable   True, if the enrollment processing error can be resolved by an end user action,
         *                          false otherwise.
         */
        public void setUserRecoverable(boolean userRecoverable) {
            this.userRecoverable = userRecoverable;
        }

        /**
         * Returns whether the problem causing the exception can be resolved by the end user.
         */
        public boolean isUserRecoverable() {
            return userRecoverable;
        }

        /**
         * Sets the error message to displayed to the user.
         *
         * @param userMessage   The message to display to the user.
         */
        public void setUserMessage(String userMessage) {
            this.userMessage = userMessage;
        }

        /**
         * Returns the error message to display to the user. This can be set for all exception, but
         * is expected when it has been set as user recoverable.
         */
        public String getUserMessage() {
            return userMessage;
        }
    }

    /**
     * UserMessage is generated by PageProcessor.processEnrollment when a user message / information or warning is encountered
     * that needs to be displayed to the user along with successful completion of the enrollment.
     */
    public inherited sharing class UserMessage {
        /**
         * Using the lightning design system ui:message severity values, specify the severity of the message.
         * The following are the valid values: confirm, info, warning
         */
        @AuraEnabled public String severity { get; set; }

        /**
         * User message to be displayed
         */
        @AuraEnabled public String message { get; set; }

        /**
         * Enrollment page reference
         */
        @AuraEnabled public String pageReference { get; set; }

        public UserMessage(String severity, String message, String pageReference) {
            this.severity = severity;
            this.message = message;
            this.pageReference = pageReference;
        }

        public UserMessage(String severity, String message) {
            this.severity = severity;
            this.message = message;
            this.pageReference = null;
        }

        public UserMessage(){
            this.severity = null;
            this.message = null;
            this.pageReference = null;
        }
    }

    private Static List<UserMessage> userMessages = new List<UserMessage>();

    /**
     * Called to add user warning, info or confirmation messages to be displayed on successful enrollment.
     *
     * @param severity  Using the lightning design system ui:message severity values, specify the severity of the message.
     *                  Valid values are: confirm, info, warning
     * @param message   Message text to be displayed
     */
    global static void addUserMessage(String severity, String message){
        userMessages.add( new UserMessage(severity,message));
    }

    public static List<UserMessage> getUserMessage(){
        return userMessages;
    }

    /**
     * List of SObjects that are to be updated as part of Enrollment process.
     */
    public static List<SObject> recordsToBeUpdated;
    /**
     * List of SObjects that are created by the individual processors as part of Enrollment process.
     */
    public static List<SObject> recordsCreated;
    /**
     * Method to get the objects that need to be updated as part of the Enrollment process.
     * This method is used by the Enrollment Wizard processor to get the objects that need to be updated.
     * @return list of SObjects that need to be updated as part of the Enrollment process.
     */
    global static List<SObject> getRecordsToBeUpdated() {
        return recordsToBeUpdated;
    }
    /**
     * Method to get the objects created in the processors as part of the Enrollment process.
     * This method should be used by the individual processors to get to know the objects that are created by
     * the preceding processors
     * @return List of SObjects created in the processors as part of the Enrollment process.
     */
    global static List<SObject> getRecordsCreated() {
        return recordsCreated;
    }
    /**
     * Method to add the object created by the processors as part of the Enrollment process.
     * This method should be used by the individual processors to store the newly created object records so that
     * other processors can use these using the getter methods.
     * @param newlyCreatedRecord SObject created by the processor.
     */
    global static void addToRecordsCreated(SObject newlyCreatedRecord) {
        recordsCreated = appendRecords(recordsCreated, newlyCreatedRecord);
    }
    /**
     * Method to add the list of objects created by the processors as part of the Enrollment process.
     * This method should be used by the individual processors to store the newly created object record so that
     * other processors can use these using the getter methods.
     * @param newlyCreatedRecords List of SObjects created by the processor.
     */
    global static void addToRecordsCreated(List<SObject> newlyCreatedRecords) {
        for(SObject newObject : newlyCreatedRecords) {
            recordsCreated = appendRecords(recordsCreated, newObject);
        }
    }
    /**
     * Method to add the list of objects that need to be updated as part of the Enrollment process.
     * This method should be used by the individual processors. Using this method avoid updating the record in
     * the processor logic and there by helps in overcoming possible governor issues to an extent.
     * @param toBeUpdatedRecord SObject that need to be updated
     */
    global static void addToRecordsToBeUpdated(SObject toBeUpdatedRecord) {
        recordsToBeUpdated = appendRecords(recordsToBeUpdated, toBeUpdatedRecord);
    }
    /**
     * Method to add the list of objects that need to be updated as part of the Enrollment process.
     * This method should be used by the individual processors. Using this method will avoid updating the record in
     * the processor logic and there by helps in overcoming possible governor issues to an extent.
     * @param toBeUpdatedObjects List of SObjects that need to be updated.
     */
    global static void addToRecordsToBeUpdated(List<SObject> toBeUpdatedRecords) {
        for(SObject updateObject : toBeUpdatedRecords) {
            recordsToBeUpdated = appendRecords(recordsToBeUpdated, updateObject);
        }
    }
    private static List<SObject> appendRecords(List<SObject> existingObjects, SObject newObject) {
        if(existingObjects == null) {
            existingObjects = new List<SObject>();
        }
        Map<String, Object> populatedFieldObjectsOfNewObject;
        Map<String, Object> populatedFieldObjects;

        Boolean isNewObject = true;
        for (Integer i = 0; i < existingObjects.size() ; i++) {
            if(existingObjects[i].Id == newObject.Id) {
                populatedFieldObjects = new Map<String, Object>();
                populatedFieldObjects.putAll(existingObjects[i].getPopulatedFieldsAsMap());
                populatedFieldObjects.putAll(newObject.getPopulatedFieldsAsMap());
                for(String key : populatedFieldObjects.keySet()) {
                    existingObjects[i].put(key, populatedFieldObjects.get(key));
                }
                isNewObject = false;
                break;
            }
        }
        if(isNewObject) {
            existingObjects.add(newObject);
        }
        return  existingObjects;
    }

}