<aura:event type="APPLICATION" description="PC_SelectedDataTableRow">
    <aura:attribute name="selectedRows" type="Object[]"/>
    <aura:attribute name="keyField" type="String"/>
    <aura:attribute name="sourceUniqueId" type="String"/>
    <aura:attribute name="actionType" type="String" default="ROW_SELECTION"/>
    <aura:attribute name="actionName" type="String" default="ROW_SELECTION"/>
</aura:event>