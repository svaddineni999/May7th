<aura:component description="PC_ViewSpecialtyPharmacyNetwork" controller="PC_ViewSpecialtyPharmacyNetworkCtller">
    <aura:attribute type="String" name="option" default="search"/>
    <aura:attribute name="prescriptionId" type="Object" access="public" default=""/>
    <aura:handler name="change" value="{! v.prescriptionId}" action="{!c.onPrescriptionIdUpdated}" />


    <aura:attribute name="namespace" type="String" default="" />
    <aura:attribute name="namespacePrefix" type="String" default="" />

    <aura:attribute name="pharmacyMultiSelect" type="Object[]" />

    <aura:attribute name="selectedPharmacies" type="Object[]" default="[]"/>
    <aura:attribute name="isValid" type="Boolean" default="true"/>

    <aura:attribute name="pharmacies" type="Object[]" default="[]"/>
    <aura:registerEvent name="addPharmacyEvent" type="c:PC_AddPharmacy"/>
    <aura:handler name="init"  value="{!this}" action="{!c.doInit}" />

    <aura:attribute name="searchInProgress" type="Boolean" default="false"/>
    <aura:attribute name="isError" type="Boolean" default="false"/>

    <aura:attribute name="toastErrorTitle" type="String" default="{!$Label.c.PC_Toast_Title_Error}" />
    <aura:attribute name="errors" type="List"/>

    <aura:if isTrue="{! (v.pharmacyMultiSelect.length > 0)}">

        <div class="mainBody">
            <div class="slds-text-body_small slds-text-align_left ">{!$Label.c.PC_PharmacyFinder_PharmaciesFound}({!v.pharmacyMultiSelect.length})</div>
            <div class="pharmacyResultBlock">
                <div class="slds-form-element__group slds-tabs--scoped__content1">
                    <div class="slds-form-element__row">
                        <table class="slds-table slds-table--bordered slds-table--cell-buffer slds-table_col-bordered">
                            <thead>
                            <tr class="slds-text-title--caps">
                                <th scope="col">
                                    <!-- <span>{!$Label.c.PC_EWP_Select_Col_Header}</span> -->
                                </th>
                                <th scope="col">
                                    <div class="slds-truncate" title="{!$Label.c.PC_PharmacyFinder_PharmacyName}">{!$Label.c.PC_PharmacyFinder_PharmacyName}</div>
                                </th>
                                <th scope="col">
                                    <div class="slds-truncate" title="{!$Label.c.PC_PharmacyFinder_Type}">{!$Label.c.PC_PharmacyFinder_Type}</div>
                                </th>
                                <th scope="col">
                                    <div class="slds-truncate" title="{!$Label.c.PC_PharmacyFinder_ZipCode}">{!$Label.c.PC_PharmacyFinder_ZipCode}</div>
                                </th>
                                <th scope="col">
                                    <div class="slds-truncate" title="{!$Label.c.PC_PharmacyFinder_Pharmacy_Contact}">{!$Label.c.PC_PharmacyFinder_Pharmacy_Contact}</div>
                                </th>
                            </tr>
                            </thead>
                            <tbody>

                            <aura:iteration items="{!v.pharmacyMultiSelect}" var="pharmacy">
                                <tr>
                                    <td>
                                        <a data-name="{! pharmacy.id}"   onclick="{!c.addPharmacies}"   >
                                            <c:svg class="slds-button__icon slds-button__icon--medium"
                                                   xlinkHref="{!$Resource.SLDS + '/assets/icons/utility-sprite/svg/symbols.svg#new'}"
                                                   ariaHidden="true"/>
                                        </a>
                                    </td>
                                    <td scope="row" data-label="">
                                        <div class="slds-truncate" title="">{!pharmacy.displayName}</div>
                                    </td>

                                    <td scope="row" data-label="">
                                        <div class="slds-truncate" title="">{!pharmacy.specialtyType}</div>
                                        <!--<aura:iteration items="{!pharmacy.additionalInfo}" var="info">
                                                    {!info.key} {!info.value}
                                                </aura:iteration> -->

                                    </td>
                                    <td scope="row" data-label="">
                                        <div class="slds-truncate" title="">{!pharmacy.zipCode}</div>
                                        <!--<aura:iteration items="{!pharmacy.additionalInfo}" var="info">
                                                    {!info.key} {!info.value}
                                                </aura:iteration> -->

                                    </td>
                                    <td scope="row" data-label="">
                                        <div class="slds-wrap" title="">
                                            <div class="slds-col">{!$Label.c.PC_Phone} : {!pharmacy.phone} </div>
                                            <div class="slds-col">{!$Label.c.PC_Fax} : {!pharmacy.fax} </div>
                                        </div>
                                    </td>


                                </tr>

                            </aura:iteration>
                            </tbody>

                        </table>
                    </div>
                </div>
            </div>

        </div>
        <span>{!$Label.c.PC_PharmacyFinder_Add_Caption}</span>
        <br/>

        <aura:set attribute="else">
            <aura:if isTrue="{!v.searchInProgress == 'true'}">
                <lightning:spinner class="slds-text-align--center" size="small" />
                <aura:set attribute="else">
                    <aura:if isTrue="{! v.errors.length > 0 }">
                        <c:PC_ErrorPanel errorHeader="{!v.toastErrorTitle}" errors="{!v.errors}"/>
                        <aura:set attribute="else">
                            <span>{!$Label.c.PC_No_Records_Found}</span>
                        </aura:set>
                    </aura:if>

                </aura:set>
            </aura:if>
        </aura:set>
    </aura:if>

</aura:component>