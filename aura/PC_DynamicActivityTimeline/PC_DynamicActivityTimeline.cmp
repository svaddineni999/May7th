*************************************************************************************
Component Name     : PC_DynamicActivityTimeline
Description         : This component is used for showing activity timeline dynamically for different objects that are
                        supported by Task.
CreatedBy           : Deloitte
Created Date        : 1 March 2021
Modification Log    :
*****************************************************************************************************
Developer                   Date                   Description
********************************************************************************************
Kanteti Kishore            1 March 2021           Initial version[PC-7427]
*****************************************************************************************
-->

<aura:component description="Dynamic Activity Timeline can be used to show timeline of tasks on different objects that are supported by Task."
                implements="forceCommunity:availableForAllPageTypes,force:hasRecordId"
                    access="global" controller="PC_DynamicActivityTimelineController">
    <!-- Design Attributes -->
    <aura:attribute name="includeChildren" type="Boolean"/>

    <!-- Data Attributes -->
    <aura:attribute name="recordId" type="Id" />
    <aura:attribute name="record" type="Object" />
    <aura:attribute name="timelineGroups" type="PC_DynamicActivityTimelineGroup" description="List of Activity Timeline Items grouped by months"/>

    <!-- Other Attributes -->
    <aura:attribute name="activeSections" type="List" />
    <aura:attribute name="isLoading" type="boolean" default="false"/>
    <aura:attribute name="errorStatus" type="String" default="{!$Label.c.PC_Lighting_Error_Message}"/>

    <ltng:require scripts="{!$Resource.PC_Resources + '/PC_Resources/js/PC_Util.js'}" afterScriptsLoaded="{!c.doInit}"/>

    <force:recordData aura:id="sobjectRecord"
                      recordId="{!v.recordId}"
                      targetFields="{!v.record}"
                      layoutType="FULL"
    />

    <!-- Loading Spinner-->
    <div class="exampleHolder">
        <aura:if isTrue="{! v.isLoading }">
            <lightning:spinner alternativeText="Loading" />
        </aura:if>
    </div>

    <!-- Task List -->
    <lightning:accordion allowMultipleSectionsOpen="true" activeSectionName="{!v.activeSections}">
        <aura:iteration items="{!v.timelineGroups}" var="activityGroup">
            <aura:if isTrue="{! !empty(activityGroup.items)}">
                <lightning:accordionSection name="{!activityGroup.sectionName}" label="{!activityGroup.name}">
                    <aura:set attribute="body">
                        <ul class="slds-timeline">
                            <aura:iteration items="{!activityGroup.items}" var="item">
                                <c:PC_DynamicActivityTimelineItems item="{!item}" />
                            </aura:iteration>
                        </ul>
                    </aura:set>
                </lightning:accordionSection>
            </aura:if>
        </aura:iteration>
    </lightning:accordion>
</aura:component>