<aura:component description="PC_Document_Management_Document_Details" controller="PC_DocumentManagement_DocumentDetails" implements="force:appHostable,flexipage:availableForAllPageTypes,force:hasRecordId,forceCommunity:availableForAllPageTypes" access="global">
    <ltng:require scripts="{! $Resource.PC_JQuery + '/PC_JQuery/js/jquery-3.1.1.min.js'}" afterScriptsLoaded="{!c.doneRendering}" />
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    <aura:handler event="force:refreshView" action="{!c.doInit}"/>
    <aura:attribute name="userId" type="String"/>
    <aura:attribute name="documentType" type="String"/>
    <aura:attribute name="recordId" type="Id" />
    <aura:attribute name="doc" type="docWrapper.object"/>
    <aura:attribute name="Document" type="String" default="{!$Label.c.PC_Document}" />
    <aura:attribute name="InboundEmail" type="String" default="{!$Label.c.PC_Inbound_Email}" />
    <aura:attribute name="details" type="PC_DocumentManagementLightningController.Object[]"/>
    <aura:attribute name="parentHasAttachments"  type="Boolean" default="true"/>
    <aura:attribute name="isParentDoc" type="Boolean" default="true" /><!--(By default all new documents could be parent)-->
    <aura:attribute name="ErrorText" type="String" default="{!$Label.c.PC_Lighting_Error_Message}" />
    <aura:attribute name="fsName" type="String" default=""/>
    <aura:attribute name="typeName" type="String" default="PC_Document__c"/>
    <aura:attribute name="fields" type="Object[]"/>
    <aura:attribute name="fieldset" type="Object[]" access="PUBLIC"/>
    <aura:attribute name="fieldsetMap" type="Map" access="PUBLIC"/>
    <aura:attribute name="form" type="Aura.Component[]" access="PUBLIC"/>
    <aura:attribute name="inputToField" type="Map"/>
    <aura:attribute name="noOfRows" type="Integer[]" />
    <aura:attribute name="noOfColumns" type="Integer[]" />
    <aura:attribute name="noOfItemsInARow" type="Integer" access="PUBLIC" default="3"/>
    <aura:attribute name="showForm" type="Boolean"  access="PRIVATE" default="FALSE"/>
    <aura:attribute name="InboundFax" type="String" default="{!$Label.c.PC_Inbound_Fax}" />
    <aura:attribute name="namespace" type="String" default="" />
    <aura:attribute name="namespacePrefix" type="String" default="" />
    <aura:attribute name="documentName" type="String"/>

    <lightning:flexipageRegionInfo />
    <div class="slds" aura:id="documentDetailsId">
        <div>
            <div class="slds-page-header" style="cursor: pointer;" onclick="{!c.showAccordion}">
                <section class="slds-clearfix">
                    <div class="slds-float--left ">
                        <lightning:icon class="slds-show" aura:id="articleOne" iconName="utility:chevrondown" size="x-small" alternativeText="Indicates open"/>
                        <lightning:icon class="slds-hide" aura:id="articleOne" iconName="utility:chevronright" size="x-small" alternativeText="Indicates close"/>
                    </div>
                    <div class="slds-m-left_large">{!$Label.c.PC_DocumentDetails}
                        <div class="slds-grid slds-gutters_small wordWrap">
                            <div class="slds-col slds-size_2-of-3">
                                <p class="slds-text-heading_label">{!v.documentType}</p>
                                <h1 class="slds-page-header__title slds-wrap slds-align-middle" title="{!if(empty(v.documentName),v.doc.Name,v.doc.Name+' - '+v.documentName)}">
                                    <b>{!v.doc.Name}</b>
                                    <aura:if isTrue="{! !empty(v.documentName)}">
                                        - <b>{!v.documentName}</b>
                                    </aura:if>
                                </h1>
                            </div>
                            <div class="slds-size_1-of-3 slds-p-left--xx-small ">
                                <p class="slds-text-heading_label">{!$Label.c.PC_Status}</p>
                                <h1 class="slds-page-header__title slds-wrap">
                                    <b>{!v.details[0].docStatusLabel}</b>
                                </h1>
                            </div>
                        </div>
                   </div>
                </section>
            </div>

            <div class="slds-show" aura:id="articleOne">
                <div class="slds-tabs--scoped">
                    <div id="tab-scoped-1" class="slds-tabs--scoped__content slds-show" role="tabpanel" aria-labelledby="tab-scoped-1__item">

                        <aura:if isTrue="{! v.showForm}">
                            <fieldset class="slds-form slds-form_stacked">

                                    <aura:iteration items="{!v.noOfRows}" var="rows" indexVar="i">
                                        <div class="slds-grid slds-gutters_small">
                                            <aura:iteration items="{!v.noOfColumns}" var="col" indexVar="j">
                                                <div class="slds-col slds-grid slds-has-flexi-truncate">
                                                    <div class="slds-form-element slds-form-element_readonly">
                                                        <aura:if isTrue="{! !empty(v.fieldsetMap)}">
                                                            <c:PC_Document_Details_FieldSet fieldset="{!v.fieldsetMap}" index="{!i+''+j}"/>
                                                        </aura:if>
                                                    </div>
                                                </div>
                                            </aura:iteration>
                                        </div>
                                    </aura:iteration>

                            </fieldset>
                        </aura:if>

                    </div>
                </div>
            </div>
        </div>
    </div>
</aura:component>