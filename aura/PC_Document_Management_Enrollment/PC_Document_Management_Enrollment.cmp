<!--
Lightning component  :  PC_Document_Management_Enrollment
Description          :
Parameters           :
Author               :
Date                 :
Modification Log     :
Haritha Reddy 		 22-Feb-2019    [PC-4340]updated the enrollment launch logic to work for both lightning and lightning console apps
Shishir Bansal       06-Sep-2019    [PC-5382] Display exact error message for 'Enrollment' Document Action Icon
Shishir Bansal       04-Feb-2020    [PC-5933]  Added functionality of opening Enrollment in new tab from Document page based on action Attributes on Document action icon(Custom Metadata)
-->
<aura:component implements="force:appHostable,flexipage:availableForRecordHome,force:hasRecordId" controller="PC_Launch_PreEnrollment" access="global" >
    
    <aura:attribute name="namespace" type="String" default="" />
    <aura:attribute name="namespacePrefix" type="String" default="" />
    <aura:attribute name="recordId" type="Id" default="NULL" access="global"/>
     <aura:attribute name="caseId" type="Id" default="NULL" access="global"/>
    <aura:attribute name="caseDetails" type="sObject"/>
    <aura:attribute name="compDetails" type="sObject"/>
     <aura:attribute name="buttonlabel" type="String" default="" />
    <aura:attribute name="ComponentName" type="Aura.Component[]"/>
    <aura:attribute name="ErrorText" type="String" default="{!$Label.c.PC_Lighting_Error_Message}" />
    <aura:attribute name="_label1" type="String" default="{!$Label.c.PC_Document_Enrollment}"/>
    <aura:attribute name="enrollmentTabLabel" type="String" default="{!$Label.c.PC_EnrollmentPatientSearchHeader}"/>
    <aura:attribute name="enrollmentComponentName" type="String" default="PC_Enrollment_Patient_Lookup"/>
    <aura:attribute name="enrollmentSearchPageName" type="String" default="Enrollment"/>
    <aura:attribute name="enrollmentTabIcon" type="String" default="action:new_lead"/>
    <aura:attribute name="errorDocStatus" type="String" default="{!$Label.c.PC_ErrorDocMgmt}" />
    <aura:attribute name="actionAttribute" type="String" access="global" default='{"openEnrollmentInNewTab":false}'/>


    <ltng:require scripts="{!$Resource.PC_Resources + '/PC_Resources/js/PC_Util.js'}" afterScriptsLoaded="{!c.doInit}"/>
    
    <div id= "PC_Document_Management_Enrollment">
        <div class="slds">

            <lightning:workspaceAPI aura:id="enrollmentDocumentWorkspace" />
            <form id="form">
                <div aria-hidden="true" role="dialog" class="slds-modal slds-modal--medium slds-fade-in-hide" aura:id="modaldialog" >
                    <div class="slds-modal__container">
                        <div class="slds-modal__header">
                            <h2 class="slds-tabs--scoped__item slds-text-heading--medium slds-active blockSection">
                                {!$Label.c.PC_EnrollmentCase_Summary_Header_Document}
                            </h2>
                            <button class="slds-button slds-button--icon-inverse slds-modal__close" onclick="{!c.hideModalBox}">
                                <c:svg class="slds-button__icon slds-button__icon--large"
                                       xlinkHref="{!$Resource.SLDS + '/assets/icons/action-sprite/svg/symbols.svg#close'}"
                                       ariaHidden="true" />
                                <span class="slds-assistive-text">{!$Label.c.PC_Close}</span>
                            </button>
                        </div>
                        <div class="slds-modal__content">
                            <div class="slds-form--compound slds-m-around--medium">
                                <!--Patient details section-->
                                <div class="slds-form-element__row">
                                    <div class="slds-form-element slds-size--1-of-2">
                                        <label class="slds-form-element__label">{!$Label.c.PC_Enroll_Sr_Col_1}</label>
                                        <div class="slds-form-element__control">
                                            <p>{!v.caseDetails.name}</p>
                                        </div>
                                    </div>
                                    <div class="slds-form-element slds-size--1-of-2">
                                        <label class="slds-form-element__label">{!$Label.c.PC_CaseSummary_Field2}</label>
                                        <div class="slds-form-element__control">
                                            <p>{!v.caseDetails.dob}</p>
                                        </div>
                                    </div>
                                </div>
                                <!--Case details section-->
                                <div class="slds-form-element__row">
                                    <div class="slds-form-element slds-size--1-of-2">
                                        <label class="slds-form-element__label">{!$Label.c.PC_CaseSummary_Field6}</label>
                                        <div class="slds-form-element__control">
                                            <p>{!v.caseDetails.casenumber}</p>
                                        </div>
                                    </div>
                                    <div class="slds-form-element slds-size--1-of-2">
                                        <label class="slds-form-element__label">{!$Label.c.PC_CaseSummary_Field5}</label>
                                        <div class="slds-form-element__control">
                                            <p>{!v.caseDetails.caseowner}</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="slds-form-element__row">
                                    <div class="slds-form-element slds-size--1-of-2">
                                        <label class="slds-form-element__label">{!$Label.c.PC_CaseSummary_Field7}</label>
                                        <div class="slds-form-element__control">
                                            <p>{!v.caseDetails.casestatus}</p>
                                        </div>
                                    </div>
                                    <div class="slds-form-element slds-size--1-of-2">
                                        <label class="slds-form-element__label">{!$Label.c.PC_CreatedDate}</label>
                                        <div class="slds-form-element__control">
                                            <p>{!v.caseDetails.createddate}</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="slds-modal__footer">
                            <div class="slds-x-small-buttons--horizontal">
                                <button class="slds-button slds-button--neutral" type="button" onclick="{!c.hideModalBox}">{!$Label.c.PC_Back_to_Document}</button>
                                <button class="slds-button slds-button--brand" type="button" onclick="{!c.goToCase}">{!$Label.c.PC_View_Case}</button>
                           	  <aura:if isTrue="{!v.buttonlabel}">
                               <button class="slds-button slds-button--brand" type="button" style="white-space: nowrap;overflow: hidden;text-overflow: ellipsis;max-width:10em;" onclick="{!c.OpenNewComponent}">{!v.buttonlabel}</button>
                              </aura:if> 
                            </div>
                        </div>
                    </div>
                </div>
                <div class="slds-backdrop slds-backdrop--hide" aura:id="backdrop"></div>
 	<div aura:id="actionIconComponent">
        {!v.body}
    </div>
                
            </form>
        </div>
    </div>
</aura:component>