<aura:component implements="lightning:appHomeTemplate" description="3 Regions" access="global">
    <aura:attribute name="top" type="Aura.Component[]" access="global"/>
    <aura:attribute name="middle" type="Aura.Component[]" access="global"/>
    <aura:attribute name="bottom" type="Aura.Component[]" access="global"/>
    <aura:attribute name="bottomWithFloatLeft" type="Aura.Component[]" access="global"/>

    <div>
        <lightning:layout>
            <lightning:layoutItem size="12"
                                  class="slds-p-left--xxx-small">
                    {!v.top}
            </lightning:layoutItem>
        </lightning:layout>
    </div>
    <div>
        <lightning:layout class="slds-p-bottom--xxx-small">
            <lightning:layoutItem size="12"
                                  class="slds-p-left--xxx-small">
                    {!v.middle}
            </lightning:layoutItem>
        </lightning:layout>
    </div>
    <div>
        <lightning:layout class="slds-p-bottom--xxx-small">
            <lightning:layoutItem size="12"
                                  class="slds-p-left--xxx-small">
                    {!v.bottom}
            </lightning:layoutItem>
        </lightning:layout>
    </div>
    <div>
        <lightning:layout class="bottomRegion slds-p-bottom--xxx-small">
            <lightning:layoutItem size="12"
                                  class="slds-p-left--xxx-small">
                    {!v.bottomWithFloatLeft}
            </lightning:layoutItem>
        </lightning:layout>
    </div>


</aura:component>